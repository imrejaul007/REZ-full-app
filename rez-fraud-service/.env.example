# Fraud Service - Environment Variables

# =============================================================================
# REQUIRED VARIABLES
# =============================================================================

# Internal service token (REQUIRED)
INTERNAL_SERVICE_TOKEN=your-secure-random-token-here

# JSON map of service tokens
INTERNAL_SERVICE_TOKENS_JSON={"payment-service":"token1","order-service":"token2"}

# =============================================================================
# OPTIONAL VARIABLES
# =============================================================================

# Port
PORT=4022

# MongoDB
MONGODB_URI=mongodb://localhost:27017/rez-fraud

# Redis
REDIS_URL=redis://localhost:6379

# Node environment
NODE_ENV=development

# =============================================================================
# SECURITY NOTES
# =============================================================================
#
# 1. INTERNAL_SERVICE_TOKEN is REQUIRED
# 2. Generate with: openssl rand -hex 32
#
