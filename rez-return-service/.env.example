# Return Service - Environment Variables

# =============================================================================
# REQUIRED VARIABLES
# =============================================================================

# Internal service token (REQUIRED)
INTERNAL_SERVICE_TOKEN=your-secure-random-token-here

# JSON map of service tokens
INTERNAL_SERVICE_TOKENS_JSON={"order-service":"token1","inventory-service":"token2"}

# =============================================================================
# OPTIONAL VARIABLES
# =============================================================================

# Port
PORT=4031

# MongoDB
MONGODB_URI=mongodb://localhost:27017/rez_returns

# Allowed CORS origins
ALLOWED_ORIGINS=https://rezapp.com,https://www.rezapp.com

# Node environment
NODE_ENV=development

# =============================================================================
# SECURITY NOTES
# =============================================================================
#
# 1. INTERNAL_SERVICE_TOKEN is REQUIRED
# 2. Generate with: openssl rand -hex 32
#
