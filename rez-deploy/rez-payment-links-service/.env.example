# =============================================================================
# REZ Payment Links Service - Environment Variables
# =============================================================================

NODE_ENV=production
PORT=3002
APP_NAME=rez-payment-links-service
APP_VERSION=1.0.0
TZ=UTC

# -----------------------------------------------------------------------------
# Logging
# -----------------------------------------------------------------------------
LOG_LEVEL=info
LOG_FORMAT=json
LOG_OUTPUT_DIR=/var/log/rez

# -----------------------------------------------------------------------------
# Database - PostgreSQL
# -----------------------------------------------------------------------------
DATABASE_HOST=postgres-primary.internal
DATABASE_PORT=5432
DATABASE_NAME=rez_payment_links
DATABASE_USERNAME=rez_payment_links_user
DATABASE_PASSWORD=change_me_in_production
DATABASE_SSL=true
DATABASE_POOL_MIN=5
DATABASE_POOL_MAX=20

# -----------------------------------------------------------------------------
# Redis
# -----------------------------------------------------------------------------
REDIS_HOST=redis.internal
REDIS_PORT=6379
REDIS_PASSWORD=change_me_in_production
REDIS_DB=2
REDIS_KEY_PREFIX=rez:payment-links:

# -----------------------------------------------------------------------------
# Payment Providers
# -----------------------------------------------------------------------------
STRIPE_API_KEY=change_me_in_production
STRIPE_WEBHOOK_SECRET=change_me_in_production
SQUARE_APPLICATION_ID=change_me_in_production
SQUARE_ACCESS_TOKEN=change_me_in_production
SQUARE_ENVIRONMENT=sandbox
BRAINTREE_MERCHANT_ID=change_me_in_production
BRAINTREE_PUBLIC_KEY=change_me_in_production
BRAINTREE_PRIVATE_KEY=change_me_in_production
BRAINTREE_ENVIRONMENT=sandbox

# -----------------------------------------------------------------------------
# Security
# -----------------------------------------------------------------------------
JWT_SECRET=change_me_in_production_min_32_chars
ENCRYPTION_KEY=change_me_in_production_32_chars
PAYMENT_LINK_SECRET=change_me_in_production
WEBHOOK_SIGNING_SECRET=change_me_in_production

# -----------------------------------------------------------------------------
# Payment Link Configuration
# -----------------------------------------------------------------------------
PAYMENT_LINK_EXPIRY_HOURS=72
PAYMENT_LINK_MAX_AMOUNT=10000
PAYMENT_LINK_MIN_AMOUNT=1
PAYMENT_LINK_CURRENCY=USD
PAYMENT_LINK_ID_LENGTH=16

# -----------------------------------------------------------------------------
# Monitoring
# -----------------------------------------------------------------------------
METRICS_ENABLED=true
METRICS_PORT=9092
METRICS_PATH=/metrics
PROMETHEUS_ENABLED=true
SENTRY_DSN=change_me_in_production

# -----------------------------------------------------------------------------
# Health Check
# -----------------------------------------------------------------------------
HEALTH_CHECK_TIMEOUT=5000
HEALTH_CHECK_DATABASE_ENABLED=true
HEALTH_CHECK_STRIPE_ENABLED=true

# -----------------------------------------------------------------------------
# Graceful Shutdown
# -----------------------------------------------------------------------------
SHUTDOWN_TIMEOUT_SECONDS=30
