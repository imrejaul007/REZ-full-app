# =============================================================================
# REZ Invoice Service - Environment Variables
# =============================================================================

NODE_ENV=production
PORT=3009
APP_NAME=rez-invoice-service
APP_VERSION=1.0.0
TZ=UTC

# -----------------------------------------------------------------------------
# Logging
# -----------------------------------------------------------------------------
LOG_LEVEL=info
LOG_FORMAT=json
LOG_OUTPUT_DIR=/var/log/rez

# -----------------------------------------------------------------------------
# Database - PostgreSQL
# -----------------------------------------------------------------------------
DATABASE_HOST=postgres-primary.internal
DATABASE_PORT=5432
DATABASE_NAME=rez_invoice
DATABASE_USERNAME=rez_invoice_user
DATABASE_PASSWORD=change_me_in_production
DATABASE_SSL=true

# -----------------------------------------------------------------------------
# Redis
# -----------------------------------------------------------------------------
REDIS_HOST=redis.internal
REDIS_PORT=6379
REDIS_PASSWORD=change_me_in_production
REDIS_DB=9
REDIS_KEY_PREFIX=rez:invoice:

# -----------------------------------------------------------------------------
# Storage - S3 Compatible
# -----------------------------------------------------------------------------
S3_ENDPOINT=https://s3.amazonaws.com
S3_REGION=us-east-1
S3_BUCKET=rez-invoices
S3_ACCESS_KEY_ID=change_me_in_production
S3_SECRET_ACCESS_KEY=change_me_in_production

# -----------------------------------------------------------------------------
# PDF Generation
# -----------------------------------------------------------------------------
PDF_GENERATION_TIMEOUT=30000
PDF_CACHE_ENABLED=true
PDF_CACHE_TTL=3600

# -----------------------------------------------------------------------------
# Security
# -----------------------------------------------------------------------------
JWT_SECRET=change_me_in_production_min_32_chars
ENCRYPTION_KEY=change_me_in_production_32_chars
INVOICE_NUMBER_SECRET=change_me_in_production

# -----------------------------------------------------------------------------
# Invoice Configuration
# -----------------------------------------------------------------------------
INVOICE_NUMBER_PREFIX=INV
INVOICE_NUMBER_SEQUENCE_START=1000
INVOICE_DUE_DAYS=30
INVOICE_AUTO_REMINDER_DAYS=7,14
INVOICE_LATE_FEE_PERCENTAGE=1.5
INVOICE_CURRENCY=USD
INVOICE_TAX_RATE=0.0

# -----------------------------------------------------------------------------
# Monitoring
# -----------------------------------------------------------------------------
METRICS_ENABLED=true
METRICS_PORT=9099
METRICS_PATH=/metrics
PROMETHEUS_ENABLED=true
SENTRY_DSN=change_me_in_production

# -----------------------------------------------------------------------------
# Health Check
# -----------------------------------------------------------------------------
HEALTH_CHECK_TIMEOUT=5000
HEALTH_CHECK_DATABASE_ENABLED=true
HEALTH_CHECK_S3_ENABLED=true

# -----------------------------------------------------------------------------
# Graceful Shutdown
# -----------------------------------------------------------------------------
SHUTDOWN_TIMEOUT_SECONDS=30
