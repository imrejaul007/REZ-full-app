# =============================================================================
# REZ Rate Limit Service - Environment Variables
# =============================================================================

NODE_ENV=production
PORT=3014
APP_NAME=rez-rate-limit
APP_VERSION=1.0.0
TZ=UTC

# -----------------------------------------------------------------------------
# Logging
# -----------------------------------------------------------------------------
LOG_LEVEL=info
LOG_FORMAT=json
LOG_OUTPUT_DIR=/var/log/rez

# -----------------------------------------------------------------------------
# Redis - Rate limiting storage
# -----------------------------------------------------------------------------
REDIS_HOST=redis.internal
REDIS_PORT=6379
REDIS_PASSWORD=change_me_in_production
REDIS_DB=14
REDIS_KEY_PREFIX=rez:ratelimit:

# -----------------------------------------------------------------------------
# Rate Limit Configuration
# -----------------------------------------------------------------------------
RATE_LIMIT_WINDOW_SECONDS=60
RATE_LIMIT_MAX_REQUESTS=100
RATE_LIMIT_BURST_MULTIPLIER=1.5
RATE_LIMIT_ALGORITHM=sliding_window
RATE_LIMIT_DISTRIBUTED=true

# -----------------------------------------------------------------------------
# Per-Endpoint Limits
# -----------------------------------------------------------------------------
RATE_LIMIT_API_DEFAULT=100
RATE_LIMIT_API_AUTH=10
RATE_LIMIT_API_PAYMENT=20
RATE_LIMIT_API_HEAVY=5

# -----------------------------------------------------------------------------
# Security
# -----------------------------------------------------------------------------
JWT_SECRET=change_me_in_production_min_32_chars
RATE_LIMIT_BYPASS_SECRET=change_me_in_production
IP_WHITELIST=

# -----------------------------------------------------------------------------
# Monitoring
# -----------------------------------------------------------------------------
METRICS_ENABLED=true
METRICS_PORT=9104
METRICS_PATH=/metrics
PROMETHEUS_ENABLED=true
SENTRY_DSN=change_me_in_production

# -----------------------------------------------------------------------------
# Health Check
# -----------------------------------------------------------------------------
HEALTH_CHECK_TIMEOUT=5000
HEALTH_CHECK_REDIS_ENABLED=true

# -----------------------------------------------------------------------------
# Graceful Shutdown
# -----------------------------------------------------------------------------
SHUTDOWN_TIMEOUT_SECONDS=30
