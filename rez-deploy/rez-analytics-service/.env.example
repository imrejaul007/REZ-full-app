# =============================================================================
# REZ Analytics Service - Environment Variables
# =============================================================================

NODE_ENV=production
PORT=3001
APP_NAME=rez-analytics-service
APP_VERSION=1.0.0
TZ=UTC

# -----------------------------------------------------------------------------
# Logging
# -----------------------------------------------------------------------------
LOG_LEVEL=info
LOG_FORMAT=json
LOG_OUTPUT_DIR=/var/log/rez
LOG_MAX_FILES=14
LOG_MAX_SIZE=100m

# -----------------------------------------------------------------------------
# Database - ClickHouse for Analytics
# -----------------------------------------------------------------------------
CLICKHOUSE_HOST=clickhouse.internal
CLICKHOUSE_PORT=8123
CLICKHOUSE_DATABASE=rez_analytics
CLICKHOUSE_USERNAME=rez_analytics
CLICKHOUSE_PASSWORD=change_me_in_production
CLICKHOUSE_HTTP_TIMEOUT=30000
CLICKHOUSE_MAX_EXECUTION_TIME=60
CLICKHOUSE_MAX_BLOCK_SIZE=10000

# -----------------------------------------------------------------------------
# PostgreSQL - User data
# -----------------------------------------------------------------------------
DATABASE_HOST=postgres-primary.internal
DATABASE_PORT=5432
DATABASE_NAME=rez_users
DATABASE_USERNAME=rez_user
DATABASE_PASSWORD=change_me_in_production
DATABASE_SSL=true

# -----------------------------------------------------------------------------
# Redis
# -----------------------------------------------------------------------------
REDIS_HOST=redis.internal
REDIS_PORT=6379
REDIS_PASSWORD=change_me_in_production
REDIS_DB=1
REDIS_KEY_PREFIX=rez:analytics:

# -----------------------------------------------------------------------------
# Kafka - Event Streaming
# -----------------------------------------------------------------------------
KAFKA_BROKERS=kafka-1.internal:9092,kafka-2.internal:9092,kafka-3.internal:9092
KAFKA_CLIENT_ID=rez-analytics-service
KAFKA_GROUP_ID=rez-analytics-consumer-group
KAFKA_TOPIC_EVENTS=rez.events
KAFKA_CONSUMER_GROUP=analytics-consumer
KAFKA_SESSION_TIMEOUT=30000
KAFKA_HEARTBEAT_INTERVAL=3000
KAFKA_MAX_POLL_RECORDS=500

# -----------------------------------------------------------------------------
# External Services
# -----------------------------------------------------------------------------
LOOKER_STUDIO_API_URL=https://api.lookerstudio.google.com
LOOKER_STUDIO_API_KEY=change_me_in_production

# -----------------------------------------------------------------------------
# Security
# -----------------------------------------------------------------------------
JWT_SECRET=change_me_in_production_min_32_chars
ENCRYPTION_KEY=change_me_in_production_32_chars

# -----------------------------------------------------------------------------
# Analytics Configuration
# -----------------------------------------------------------------------------
ANALYTICS_BATCH_SIZE=1000
ANALYTICS_FLUSH_INTERVAL_MS=5000
ANALYTICS_RETENTION_DAYS=90
EVENT_DEDUP_WINDOW_MS=5000

# -----------------------------------------------------------------------------
# Reporting
# -----------------------------------------------------------------------------
REPORT_GENERATION_TIMEOUT=300000
REPORT_MAX_ROWS=100000
REPORT_CACHE_TTL=3600

# -----------------------------------------------------------------------------
# Monitoring
# -----------------------------------------------------------------------------
METRICS_ENABLED=true
METRICS_PORT=9091
METRICS_PATH=/metrics
PROMETHEUS_ENABLED=true
JAEGER_ENABLED=true
SENTRY_DSN=change_me_in_production

# -----------------------------------------------------------------------------
# Health Check
# -----------------------------------------------------------------------------
HEALTH_CHECK_TIMEOUT=5000
HEALTH_CHECK_CLICKHOUSE_ENABLED=true
HEALTH_CHECK_KAFKA_ENABLED=true

# -----------------------------------------------------------------------------
# Graceful Shutdown
# -----------------------------------------------------------------------------
SHUTDOWN_TIMEOUT_SECONDS=30
