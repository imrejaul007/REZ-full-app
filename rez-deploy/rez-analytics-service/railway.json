{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "DOCKERFILE",
    "dockerfilePath": "Dockerfile",
    "buildCommand": "npm run build"
  },
  "deploy": {
    "numReplicas": 2,
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 10,
    "healthCheckCommand": {
      "type": "HTTP",
      "path": "/health",
      "intervalSeconds": 30,
      "timeoutSeconds": 10,
      "restartThreshold": 3
    },
    "readinessCheckCommand": {
      "type": "HTTP",
      "path": "/ready",
      "intervalSeconds": 10,
      "timeoutSeconds": 5
    },
    "startCommand": "node dist/main.js",
    "metadata": {
      "containerPort": 3001
    },
    "resources": {
      "cpu": {
        "type": "SHARED",
        "value": 1
      },
      "memory": {
        "type": "CONVENTIONAL",
        "value": 1024
      }
    },
    "autoscaling": {
      "enabled": true,
      "min": 2,
      "max": 8,
      "targetCpuPercentage": 70,
      "targetMemoryPercentage": 80
    },
    "regions": ["us-west-2", "us-east-1"],
    "regionPreference": "us-west-2"
  },
  "variables": {
    "NODE_ENV": "production",
    "PORT": "3001",
    "APP_NAME": "rez-analytics-service"
  },
  "metrics": {
    "prometheus": {
      "enabled": true,
      "path": "/metrics"
    }
  },
  "logging": {
    "driver": "json-file",
    "options": {
      "max-size": "100m",
      "max-file": "5"
    }
  }
}
