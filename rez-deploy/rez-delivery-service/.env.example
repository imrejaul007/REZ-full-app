# =============================================================================
# REZ Delivery Service - Environment Variables
# =============================================================================
# Copy this file to .env and fill in the values
# NEVER commit .env to version control
# =============================================================================

# -----------------------------------------------------------------------------
# Application
# -----------------------------------------------------------------------------
NODE_ENV=production
PORT=3000
APP_NAME=rez-delivery-service
APP_VERSION=1.0.0
TZ=UTC

# -----------------------------------------------------------------------------
# Logging
# -----------------------------------------------------------------------------
LOG_LEVEL=info
LOG_FORMAT=json
LOG_OUTPUT_DIR=/var/log/rez
LOG_MAX_FILES=14
LOG_MAX_SIZE=100m

# -----------------------------------------------------------------------------
# Database - PostgreSQL
# -----------------------------------------------------------------------------
DATABASE_HOST=postgres-primary.internal
DATABASE_PORT=5432
DATABASE_NAME=rez_delivery
DATABASE_USERNAME=rez_delivery_user
DATABASE_PASSWORD=change_me_in_production
DATABASE_SSL=true
DATABASE_POOL_MIN=5
DATABASE_POOL_MAX=20
DATABASE_POOL_IDLE_TIMEOUT=30000
DATABASE_CONNECTION_TIMEOUT=5000

# -----------------------------------------------------------------------------
# Redis / Cache
# -----------------------------------------------------------------------------
REDIS_HOST=redis.internal
REDIS_PORT=6379
REDIS_PASSWORD=change_me_in_production
REDIS_DB=0
REDIS_KEY_PREFIX=rez:delivery:
REDIS_TTL_DEFAULT=3600
REDIS_TTL_SHORT=300
REDIS_TTL_LONG=86400

# -----------------------------------------------------------------------------
# Message Queue - RabbitMQ
# -----------------------------------------------------------------------------
RABBITMQ_HOST=rabbitmq.internal
RABBITMQ_PORT=5672
RABBITMQ_USERNAME=rez_delivery
RABBITMQ_PASSWORD=change_me_in_production
RABBITMQ_VHOST=rez_delivery
RABBITMQ_PREFETCH=10
RABBITMQ_EXCHANGE=rez.delivery.exchange
RABBITMQ_QUEUE=rez.delivery.queue
RABBITMQ_DEAD_LETTER_QUEUE=rez.delivery.dlq

# -----------------------------------------------------------------------------
# External Services
# -----------------------------------------------------------------------------
# Delivery Provider API (e.g., DoorDash, Uber Eats, etc.)
DELIVERY_PROVIDER_API_URL=https://api.delivery-provider.com
DELIVERY_PROVIDER_API_KEY=change_me_in_production
DELIVERY_PROVIDER_API_TIMEOUT=30000
DELIVERY_PROVIDER_WEBHOOK_SECRET=change_me_in_production

# Geocoding Service
GEOCODING_API_URL=https://maps.googleapis.com/maps/api/geocode
GEOCODING_API_KEY=change_me_in_production

# -----------------------------------------------------------------------------
# Security
# -----------------------------------------------------------------------------
JWT_SECRET=change_me_in_production_min_32_chars
JWT_EXPIRATION=1h
BCRYPT_ROUNDS=12
ENCRYPTION_KEY=change_me_in_production_32_chars

# -----------------------------------------------------------------------------
# Rate Limiting
# -----------------------------------------------------------------------------
RATE_LIMIT_TTL=60
RATE_LIMIT_MAX=100
RATE_LIMIT_ENDPOINT_TTL=60
RATE_LIMIT_ENDPOINT_MAX=10

# -----------------------------------------------------------------------------
# Monitoring & Observability
# -----------------------------------------------------------------------------
METRICS_ENABLED=true
METRICS_PORT=9090
METRICS_PATH=/metrics
PROMETHEUS_ENABLED=true
JAEGER_ENABLED=true
JAEGER_AGENT_HOST=jaeger-agent.internal
JAEGER_AGENT_PORT=6831
SENTRY_DSN=change_me_in_production

# -----------------------------------------------------------------------------
# Feature Flags
# -----------------------------------------------------------------------------
FEATURE_REAL_TIME_TRACKING=true
FEATURE_ETA_PREDICTION=true
FEATURE_MULTI_PROVIDER=true
FEATURE_BATCH_ORDERS=true

# -----------------------------------------------------------------------------
# Business Logic
# -----------------------------------------------------------------------------
DEFAULT_DELIVERY_RADIUS_KM=10
MAX_DELIVERY_RADIUS_KM=25
DELIVERY_TIMEOUT_MINUTES=45
DRIVER_ASSIGNMENT_TIMEOUT_SECONDS=120
ORDER_DISPATCH_STRATEGY=closest_available

# -----------------------------------------------------------------------------
# Health Check
# -----------------------------------------------------------------------------
HEALTH_CHECK_TIMEOUT=5000
HEALTH_CHECK_DATABASE_ENABLED=true
HEALTH_CHECK_REDIS_ENABLED=true
HEALTH_CHECK_RABBITMQ_ENABLED=true

# -----------------------------------------------------------------------------
# Graceful Shutdown
# -----------------------------------------------------------------------------
SHUTDOWN_TIMEOUT_SECONDS=30
FORCE_SHUTDOWN_TIMEOUT_SECONDS=60
