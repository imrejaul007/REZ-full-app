{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "DOCKERFILE",
    "dockerfilePath": "Dockerfile",
    "buildCommand": "npm run build",
    "watchPatterns": ["src/**"]
  },
  "deploy": {
    "numReplicas": 2,
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 10,
    "healthCheckCommand": {
      "type": "HTTP",
      "path": "/health",
      "intervalSeconds": 30,
      "timeoutSeconds": 10,
      "restartThreshold": 3
    },
    "readinessCheckCommand": {
      "type": "HTTP",
      "path": "/ready",
      "intervalSeconds": 10,
      "timeoutSeconds": 5
    },
    "startCommand": "node dist/main.js",
    "metadata": {
      "containerPort": 3000
    },
    "resources": {
      "cpu": {
        "type": "SHARED",
        "value": 0.5
      },
      "memory": {
        "type": "CONVENTIONAL",
        "value": 512
      }
    },
    " Autoscaling": {
      "enabled": true,
      "min": 2,
      "max": 10,
      "targetCpuPercentage": 70,
      "targetMemoryPercentage": 80
    },
    "regions": ["us-west-2", "us-east-1"],
    "regionPreference": "us-west-2"
  },
  "variables": {
    "NODE_ENV": "production",
    "PORT": "3000",
    "APP_NAME": "rez-delivery-service"
  },
  "metrics": {
    "prometheus": {
      "enabled": true,
      "path": "/metrics"
    }
  },
  "logging": {
    "driver": "json-file",
    "options": {
      "max-size": "100m",
      "max-file": "5"
    }
  },
  "environments": {
    "production": {
      "variables": {
        "LOG_LEVEL": "info",
        "DATABASE_SSL": "true"
      }
    },
    "staging": {
      "variables": {
        "LOG_LEVEL": "debug",
        "DATABASE_SSL": "false"
      }
    }
  },
  "ephemeralDisk": {
    "enabled": true,
    "sizeMB": 512
  }
}
