# =============================================================================
# REZ Currency Service - Environment Variables
# =============================================================================

NODE_ENV=production
PORT=3008
APP_NAME=rez-currency-service
APP_VERSION=1.0.0
TZ=UTC

# -----------------------------------------------------------------------------
# Logging
# -----------------------------------------------------------------------------
LOG_LEVEL=info
LOG_FORMAT=json
LOG_OUTPUT_DIR=/var/log/rez

# -----------------------------------------------------------------------------
# Database - PostgreSQL
# -----------------------------------------------------------------------------
DATABASE_HOST=postgres-primary.internal
DATABASE_PORT=5432
DATABASE_NAME=rez_currency
DATABASE_USERNAME=rez_currency_user
DATABASE_PASSWORD=change_me_in_production
DATABASE_SSL=true

# -----------------------------------------------------------------------------
# Redis
# -----------------------------------------------------------------------------
REDIS_HOST=redis.internal
REDIS_PORT=6379
REDIS_PASSWORD=change_me_in_production
REDIS_DB=8
REDIS_KEY_PREFIX=rez:currency:

# -----------------------------------------------------------------------------
# External Services
# -----------------------------------------------------------------------------
EXCHANGE_RATE_API_URL=https://api.exchangerate-api.com
EXCHANGE_RATE_API_KEY=change_me_in_production
FIXER_API_KEY=change_me_in_production

# -----------------------------------------------------------------------------
# Security
# -----------------------------------------------------------------------------
JWT_SECRET=change_me_in_production_min_32_chars
ENCRYPTION_KEY=change_me_in_production_32_chars

# -----------------------------------------------------------------------------
# Currency Configuration
# -----------------------------------------------------------------------------
CURRENCY_DEFAULT=USD
CURRENCY_CACHE_TTL_SECONDS=3600
CURRENCY_CACHE_HOURS=1
CURRENCY_FALLBACK_ENABLED=true
CURRENCY_PRECISION=2
CURRENCY_ROUNDING_MODE=half_even

# -----------------------------------------------------------------------------
# Supported Currencies
# -----------------------------------------------------------------------------
CURRENCY_ENABLED_LIST=USD,EUR,GBP,CAD,AUD,JPY,CHF,CNY,INR,MXN,BRL

# -----------------------------------------------------------------------------
# Monitoring
# -----------------------------------------------------------------------------
METRICS_ENABLED=true
METRICS_PORT=9098
METRICS_PATH=/metrics
PROMETHEUS_ENABLED=true
SENTRY_DSN=change_me_in_production

# -----------------------------------------------------------------------------
# Health Check
# -----------------------------------------------------------------------------
HEALTH_CHECK_TIMEOUT=5000
HEALTH_CHECK_DATABASE_ENABLED=true

# -----------------------------------------------------------------------------
# Graceful Shutdown
# -----------------------------------------------------------------------------
SHUTDOWN_TIMEOUT_SECONDS=30
