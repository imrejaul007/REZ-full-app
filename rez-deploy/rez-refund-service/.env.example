# =============================================================================
# REZ Refund Service - Environment Variables
# =============================================================================

NODE_ENV=production
PORT=3011
APP_NAME=rez-refund-service
APP_VERSION=1.0.0
TZ=UTC

# -----------------------------------------------------------------------------
# Logging
# -----------------------------------------------------------------------------
LOG_LEVEL=info
LOG_FORMAT=json
LOG_OUTPUT_DIR=/var/log/rez

# -----------------------------------------------------------------------------
# Database - PostgreSQL
# -----------------------------------------------------------------------------
DATABASE_HOST=postgres-primary.internal
DATABASE_PORT=5432
DATABASE_NAME=rez_refund
DATABASE_USERNAME=rez_refund_user
DATABASE_PASSWORD=change_me_in_production
DATABASE_SSL=true

# -----------------------------------------------------------------------------
# Redis
# -----------------------------------------------------------------------------
REDIS_HOST=redis.internal
REDIS_PORT=6379
REDIS_PASSWORD=change_me_in_production
REDIS_DB=11
REDIS_KEY_PREFIX=rez:refund:

# -----------------------------------------------------------------------------
# Payment Providers
# -----------------------------------------------------------------------------
STRIPE_API_KEY=change_me_in_production
SQUARE_ACCESS_TOKEN=change_me_in_production
BRAINTREE_MERCHANT_ID=change_me_in_production
BRAINTREE_PRIVATE_KEY=change_me_in_production

# -----------------------------------------------------------------------------
# Message Queue - RabbitMQ
# -----------------------------------------------------------------------------
RABBITMQ_HOST=rabbitmq.internal
RABBITMQ_PORT=5672
RABBITMQ_USERNAME=rez_refund
RABBITMQ_PASSWORD=change_me_in_production
RABBITMQ_VHOST=rez_refund
RABBITMQ_QUEUE=rez.refund.queue

# -----------------------------------------------------------------------------
# Security
# -----------------------------------------------------------------------------
JWT_SECRET=change_me_in_production_min_32_chars
ENCRYPTION_KEY=change_me_in_production_32_chars

# -----------------------------------------------------------------------------
# Refund Configuration
# -----------------------------------------------------------------------------
REFUND_AUTO_APPROVE_THRESHOLD=50
REFUND_MAX_AMOUNT=10000
REFUND_WINDOW_DAYS=30
REFUND_REASON_REQUIRED=true
REFUND_APPROVAL_WORKFLOW=auto

# -----------------------------------------------------------------------------
# Monitoring
# -----------------------------------------------------------------------------
METRICS_ENABLED=true
METRICS_PORT=9101
METRICS_PATH=/metrics
PROMETHEUS_ENABLED=true
SENTRY_DSN=change_me_in_production

# -----------------------------------------------------------------------------
# Health Check
# -----------------------------------------------------------------------------
HEALTH_CHECK_TIMEOUT=5000
HEALTH_CHECK_DATABASE_ENABLED=true

# -----------------------------------------------------------------------------
# Graceful Shutdown
# -----------------------------------------------------------------------------
SHUTDOWN_TIMEOUT_SECONDS=30
