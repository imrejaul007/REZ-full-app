# =============================================================================
# REZ WebSocket Hub - Environment Variables
# =============================================================================

NODE_ENV=production
PORT=3013
APP_NAME=rez-websocket-hub
APP_VERSION=1.0.0
TZ=UTC

# -----------------------------------------------------------------------------
# Logging
# -----------------------------------------------------------------------------
LOG_LEVEL=info
LOG_FORMAT=json
LOG_OUTPUT_DIR=/var/log/rez

# -----------------------------------------------------------------------------
# Redis - Pub/Sub
# -----------------------------------------------------------------------------
REDIS_HOST=redis.internal
REDIS_PORT=6379
REDIS_PASSWORD=change_me_in_production
REDIS_DB=13
REDIS_KEY_PREFIX=rez:websocket:
REDIS_PUBSUB_ENABLED=true

# -----------------------------------------------------------------------------
# WebSocket Configuration
# -----------------------------------------------------------------------------
WEBSOCKET_MAX_CONNECTIONS=10000
WEBSOCKET_HEARTBEAT_INTERVAL=30000
WEBSOCKET_HEARTBEAT_TIMEOUT=60000
WEBSOCKET_MESSAGE_MAX_SIZE=65536
WEBSOCKET_QUEUE_SIZE=1000
WEBSOCKET_BACKPRESSURE_THRESHOLD=100

# -----------------------------------------------------------------------------
# Security
# -----------------------------------------------------------------------------
JWT_SECRET=change_me_in_production_min_32_chars
WEBSOCKET_AUTH_ENABLED=true
WEBSOCKET_RATE_LIMIT_PER_MINUTE=100
WEBSOCKET_IP_WHITELIST=

# -----------------------------------------------------------------------------
# Monitoring
# -----------------------------------------------------------------------------
METRICS_ENABLED=true
METRICS_PORT=9103
METRICS_PATH=/metrics
PROMETHEUS_ENABLED=true
SENTRY_DSN=change_me_in_production

# -----------------------------------------------------------------------------
# Health Check
# -----------------------------------------------------------------------------
HEALTH_CHECK_TIMEOUT=5000
HEALTH_CHECK_REDIS_ENABLED=true

# -----------------------------------------------------------------------------
# Graceful Shutdown
# -----------------------------------------------------------------------------
SHUTDOWN_TIMEOUT_SECONDS=30
