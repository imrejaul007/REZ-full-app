# =============================================================================
# REZ Journey Service - Environment Variables
# =============================================================================

NODE_ENV=production
PORT=3003
APP_NAME=rez-journey-service
APP_VERSION=1.0.0
TZ=UTC

# -----------------------------------------------------------------------------
# Logging
# -----------------------------------------------------------------------------
LOG_LEVEL=info
LOG_FORMAT=json
LOG_OUTPUT_DIR=/var/log/rez

# -----------------------------------------------------------------------------
# Database - PostgreSQL
# -----------------------------------------------------------------------------
DATABASE_HOST=postgres-primary.internal
DATABASE_PORT=5432
DATABASE_NAME=rez_journey
DATABASE_USERNAME=rez_journey_user
DATABASE_PASSWORD=change_me_in_production
DATABASE_SSL=true

# -----------------------------------------------------------------------------
# Redis
# -----------------------------------------------------------------------------
REDIS_HOST=redis.internal
REDIS_PORT=6379
REDIS_PASSWORD=change_me_in_production
REDIS_DB=3
REDIS_KEY_PREFIX=rez:journey:

# -----------------------------------------------------------------------------
# Kafka - Event Streaming
# -----------------------------------------------------------------------------
KAFKA_BROKERS=kafka-1.internal:9092,kafka-2.internal:9092,kafka-3.internal:9092
KAFKA_CLIENT_ID=rez-journey-service
KAFKA_GROUP_ID=rez-journey-consumer-group
KAFKA_TOPIC_EVENTS=rez.journey.events

# -----------------------------------------------------------------------------
# Security
# -----------------------------------------------------------------------------
JWT_SECRET=change_me_in_production_min_32_chars
ENCRYPTION_KEY=change_me_in_production_32_chars

# -----------------------------------------------------------------------------
# Journey Configuration
# -----------------------------------------------------------------------------
JOURNEY_STEP_TIMEOUT_HOURS=24
JOURNEY_MAX_STEPS=50
JOURNEY_COMPLETION_SCORE=100
JOURNEY_ABANDONMENT_THRESHOLD_HOURS=48

# -----------------------------------------------------------------------------
# Monitoring
# -----------------------------------------------------------------------------
METRICS_ENABLED=true
METRICS_PORT=9093
METRICS_PATH=/metrics
PROMETHEUS_ENABLED=true
SENTRY_DSN=change_me_in_production

# -----------------------------------------------------------------------------
# Health Check
# -----------------------------------------------------------------------------
HEALTH_CHECK_TIMEOUT=5000
HEALTH_CHECK_DATABASE_ENABLED=true

# -----------------------------------------------------------------------------
# Graceful Shutdown
# -----------------------------------------------------------------------------
SHUTDOWN_TIMEOUT_SECONDS=30
