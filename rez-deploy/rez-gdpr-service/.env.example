# =============================================================================
# REZ GDPR Service - Environment Variables
# =============================================================================

NODE_ENV=production
PORT=3005
APP_NAME=rez-gdpr-service
APP_VERSION=1.0.0
TZ=UTC

# -----------------------------------------------------------------------------
# Logging
# -----------------------------------------------------------------------------
LOG_LEVEL=info
LOG_FORMAT=json
LOG_OUTPUT_DIR=/var/log/rez

# -----------------------------------------------------------------------------
# Database - PostgreSQL
# -----------------------------------------------------------------------------
DATABASE_HOST=postgres-primary.internal
DATABASE_PORT=5432
DATABASE_NAME=rez_gdpr
DATABASE_USERNAME=rez_gdpr_user
DATABASE_PASSWORD=change_me_in_production
DATABASE_SSL=true

# -----------------------------------------------------------------------------
# Redis
# -----------------------------------------------------------------------------
REDIS_HOST=redis.internal
REDIS_PORT=6379
REDIS_PASSWORD=change_me_in_production
REDIS_DB=5
REDIS_KEY_PREFIX=rez:gdpr:

# -----------------------------------------------------------------------------
# Storage - S3 Compatible
# -----------------------------------------------------------------------------
S3_ENDPOINT=https://s3.amazonaws.com
S3_REGION=us-east-1
S3_BUCKET=rez-gdpr-exports
S3_ACCESS_KEY_ID=change_me_in_production
S3_SECRET_ACCESS_KEY=change_me_in_production

# -----------------------------------------------------------------------------
# Security
# -----------------------------------------------------------------------------
JWT_SECRET=change_me_in_production_min_32_chars
ENCRYPTION_KEY=change_me_in_production_32_chars
ANONYMIZATION_KEY=change_me_in_production_32_chars

# -----------------------------------------------------------------------------
# GDPR Configuration
# -----------------------------------------------------------------------------
GDPR_DATA_RETENTION_DAYS=90
GDPR_ANONYMIZATION_ENABLED=true
GDPR_EXPORT_FORMAT=json
GDPR_MAX_EXPORT_SIZE_MB=100
GDPR_REQUEST_TIMEOUT_HOURS=72
GDPR_BACKUP_ENABLED=true
GDPR_BACKUP_RETENTION_DAYS=365

# -----------------------------------------------------------------------------
# Monitoring
# -----------------------------------------------------------------------------
METRICS_ENABLED=true
METRICS_PORT=9095
METRICS_PATH=/metrics
PROMETHEUS_ENABLED=true
SENTRY_DSN=change_me_in_production

# -----------------------------------------------------------------------------
# Health Check
# -----------------------------------------------------------------------------
HEALTH_CHECK_TIMEOUT=5000
HEALTH_CHECK_DATABASE_ENABLED=true
HEALTH_CHECK_S3_ENABLED=true

# -----------------------------------------------------------------------------
# Graceful Shutdown
# -----------------------------------------------------------------------------
SHUTDOWN_TIMEOUT_SECONDS=30
