# =============================================================================
# REZ Validation Service - Environment Variables
# =============================================================================

NODE_ENV=production
PORT=3006
APP_NAME=rez-validation-service
APP_VERSION=1.0.0
TZ=UTC

# -----------------------------------------------------------------------------
# Logging
# -----------------------------------------------------------------------------
LOG_LEVEL=info
LOG_FORMAT=json
LOG_OUTPUT_DIR=/var/log/rez

# -----------------------------------------------------------------------------
# Database - PostgreSQL
# -----------------------------------------------------------------------------
DATABASE_HOST=postgres-primary.internal
DATABASE_PORT=5432
DATABASE_NAME=rez_validation
DATABASE_USERNAME=rez_validation_user
DATABASE_PASSWORD=change_me_in_production
DATABASE_SSL=true

# -----------------------------------------------------------------------------
# Redis
# -----------------------------------------------------------------------------
REDIS_HOST=redis.internal
REDIS_PORT=6379
REDIS_PASSWORD=change_me_in_production
REDIS_DB=6
REDIS_KEY_PREFIX=rez:validation:

# -----------------------------------------------------------------------------
# External Services
# -----------------------------------------------------------------------------
GOOGLE_MAPS_API_KEY=change_me_in_production
TAX_CALCULATION_API_URL=https://api.taxcloud.com
TAX_CALCULATION_API_KEY=change_me_in_production
EMAIL_VERIFICATION_API_KEY=change_me_in_production

# -----------------------------------------------------------------------------
# Security
# -----------------------------------------------------------------------------
JWT_SECRET=change_me_in_production_min_32_chars
ENCRYPTION_KEY=change_me_in_production_32_chars

# -----------------------------------------------------------------------------
# Validation Configuration
# -----------------------------------------------------------------------------
VALIDATION_STRICT_MODE=true
VALIDATION_MAX_FIELD_LENGTH=1000
VALIDATION_ALLOWED_IMAGE_TYPES=image/jpeg,image/png,image/webp
VALIDATION_MAX_IMAGE_SIZE_MB=10
VALIDATION_CACHE_TTL_SECONDS=300

# -----------------------------------------------------------------------------
# Monitoring
# -----------------------------------------------------------------------------
METRICS_ENABLED=true
METRICS_PORT=9096
METRICS_PATH=/metrics
PROMETHEUS_ENABLED=true
SENTRY_DSN=change_me_in_production

# -----------------------------------------------------------------------------
# Health Check
# -----------------------------------------------------------------------------
HEALTH_CHECK_TIMEOUT=5000
HEALTH_CHECK_DATABASE_ENABLED=true

# -----------------------------------------------------------------------------
# Graceful Shutdown
# -----------------------------------------------------------------------------
SHUTDOWN_TIMEOUT_SECONDS=30
