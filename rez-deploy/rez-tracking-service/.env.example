# =============================================================================
# REZ Tracking Service - Environment Variables
# =============================================================================

NODE_ENV=production
PORT=3012
APP_NAME=rez-tracking-service
APP_VERSION=1.0.0
TZ=UTC

# -----------------------------------------------------------------------------
# Logging
# -----------------------------------------------------------------------------
LOG_LEVEL=info
LOG_FORMAT=json
LOG_OUTPUT_DIR=/var/log/rez

# -----------------------------------------------------------------------------
# Database - PostgreSQL
# -----------------------------------------------------------------------------
DATABASE_HOST=postgres-primary.internal
DATABASE_PORT=5432
DATABASE_NAME=rez_tracking
DATABASE_USERNAME=rez_tracking_user
DATABASE_PASSWORD=change_me_in_production
DATABASE_SSL=true

# -----------------------------------------------------------------------------
# Redis
# -----------------------------------------------------------------------------
REDIS_HOST=redis.internal
REDIS_PORT=6379
REDIS_PASSWORD=change_me_in_production
REDIS_DB=12
REDIS_KEY_PREFIX=rez:tracking:

# -----------------------------------------------------------------------------
# Kafka - Real-time events
# -----------------------------------------------------------------------------
KAFKA_BROKERS=kafka-1.internal:9092,kafka-2.internal:9092,kafka-3.internal:9092
KAFKA_CLIENT_ID=rez-tracking-service
KAFKA_GROUP_ID=rez-tracking-consumer-group
KAFKA_TOPIC_EVENTS=rez.tracking.events

# -----------------------------------------------------------------------------
# Security
# -----------------------------------------------------------------------------
JWT_SECRET=change_me_in_production_min_32_chars
ENCRYPTION_KEY=change_me_in_production_32_chars

# -----------------------------------------------------------------------------
# Tracking Configuration
# -----------------------------------------------------------------------------
TRACKING_UPDATE_INTERVAL_SECONDS=30
TRACKING_HISTORY_RETENTION_DAYS=30
TRACKING_MAX_POINTS_PER_TRIP=1000
TRACKING_GPS_ACCURACY_THRESHOLD_METERS=50
TRACKING_ETA_UPDATE_INTERVAL=60

# -----------------------------------------------------------------------------
# Monitoring
# -----------------------------------------------------------------------------
METRICS_ENABLED=true
METRICS_PORT=9102
METRICS_PATH=/metrics
PROMETHEUS_ENABLED=true
SENTRY_DSN=change_me_in_production

# -----------------------------------------------------------------------------
# Health Check
# -----------------------------------------------------------------------------
HEALTH_CHECK_TIMEOUT=5000
HEALTH_CHECK_DATABASE_ENABLED=true
HEALTH_CHECK_REDIS_ENABLED=true
HEALTH_CHECK_KAFKA_ENABLED=true

# -----------------------------------------------------------------------------
# Graceful Shutdown
# -----------------------------------------------------------------------------
SHUTDOWN_TIMEOUT_SECONDS=30
