# =============================================================================
# REZ Cohort Service - Environment Variables
# =============================================================================

NODE_ENV=production
PORT=3007
APP_NAME=rez-cohort-service
APP_VERSION=1.0.0
TZ=UTC

# -----------------------------------------------------------------------------
# Logging
# -----------------------------------------------------------------------------
LOG_LEVEL=info
LOG_FORMAT=json
LOG_OUTPUT_DIR=/var/log/rez

# -----------------------------------------------------------------------------
# Database - PostgreSQL
# -----------------------------------------------------------------------------
DATABASE_HOST=postgres-primary.internal
DATABASE_PORT=5432
DATABASE_NAME=rez_cohort
DATABASE_USERNAME=rez_cohort_user
DATABASE_PASSWORD=change_me_in_production
DATABASE_SSL=true

# -----------------------------------------------------------------------------
# ClickHouse - Analytics
# -----------------------------------------------------------------------------
CLICKHOUSE_HOST=clickhouse.internal
CLICKHOUSE_PORT=8123
CLICKHOUSE_DATABASE=rez_analytics
CLICKHOUSE_USERNAME=rez_cohort
CLICKHOUSE_PASSWORD=change_me_in_production

# -----------------------------------------------------------------------------
# Redis
# -----------------------------------------------------------------------------
REDIS_HOST=redis.internal
REDIS_PORT=6379
REDIS_PASSWORD=change_me_in_production
REDIS_DB=7
REDIS_KEY_PREFIX=rez:cohort:

# -----------------------------------------------------------------------------
# Kafka
# -----------------------------------------------------------------------------
KAFKA_BROKERS=kafka-1.internal:9092,kafka-2.internal:9092,kafka-3.internal:9092
KAFKA_CLIENT_ID=rez-cohort-service
KAFKA_GROUP_ID=rez-cohort-consumer-group

# -----------------------------------------------------------------------------
# Security
# -----------------------------------------------------------------------------
JWT_SECRET=change_me_in_production_min_32_chars
ENCRYPTION_KEY=change_me_in_production_32_chars

# -----------------------------------------------------------------------------
# Cohort Configuration
# -----------------------------------------------------------------------------
COHORT_MIN_SIZE=10
COHORT_MAX_SIZE=10000
COHORT_REFRESH_INTERVAL_HOURS=24
COHORT_ATTRIBUTION_WINDOW_DAYS=30
COHORT_RETENTION_PERIODS=7,14,30,60,90

# -----------------------------------------------------------------------------
# Monitoring
# -----------------------------------------------------------------------------
METRICS_ENABLED=true
METRICS_PORT=9097
METRICS_PATH=/metrics
PROMETHEUS_ENABLED=true
SENTRY_DSN=change_me_in_production

# -----------------------------------------------------------------------------
# Health Check
# -----------------------------------------------------------------------------
HEALTH_CHECK_TIMEOUT=5000
HEALTH_CHECK_DATABASE_ENABLED=true
HEALTH_CHECK_CLICKHOUSE_ENABLED=true

# -----------------------------------------------------------------------------
# Graceful Shutdown
# -----------------------------------------------------------------------------
SHUTDOWN_TIMEOUT_SECONDS=30
