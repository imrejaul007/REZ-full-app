# =============================================================================
# REZ Menu Service - Environment Variables
# =============================================================================

NODE_ENV=production
PORT=3010
APP_NAME=rez-menu-service
APP_VERSION=1.0.0
TZ=UTC

# -----------------------------------------------------------------------------
# Logging
# -----------------------------------------------------------------------------
LOG_LEVEL=info
LOG_FORMAT=json
LOG_OUTPUT_DIR=/var/log/rez

# -----------------------------------------------------------------------------
# Database - PostgreSQL
# -----------------------------------------------------------------------------
DATABASE_HOST=postgres-primary.internal
DATABASE_PORT=5432
DATABASE_NAME=rez_menu
DATABASE_USERNAME=rez_menu_user
DATABASE_PASSWORD=change_me_in_production
DATABASE_SSL=true

# -----------------------------------------------------------------------------
# Redis
# -----------------------------------------------------------------------------
REDIS_HOST=redis.internal
REDIS_PORT=6379
REDIS_PASSWORD=change_me_in_production
REDIS_DB=10
REDIS_KEY_PREFIX=rez:menu:

# -----------------------------------------------------------------------------
# Storage - S3 Compatible (for menu images)
# -----------------------------------------------------------------------------
S3_ENDPOINT=https://s3.amazonaws.com
S3_REGION=us-east-1
S3_BUCKET=rez-menu-images
S3_ACCESS_KEY_ID=change_me_in_production
S3_SECRET_ACCESS_KEY=change_me_in_production
S3_CDN_URL=https://cdn.rez.app

# -----------------------------------------------------------------------------
# Security
# -----------------------------------------------------------------------------
JWT_SECRET=change_me_in_production_min_32_chars
ENCRYPTION_KEY=change_me_in_production_32_chars

# -----------------------------------------------------------------------------
# Menu Configuration
# -----------------------------------------------------------------------------
MENU_CACHE_TTL_SECONDS=300
MENU_IMAGE_MAX_SIZE_MB=5
MENU_IMAGE_ALLOWED_TYPES=image/jpeg,image/png,image/webp
MENU_MAX_ITEMS_PER_CATEGORY=100
MENU_MAX_MODIFIERS_PER_ITEM=20
MENU_VERSIONING_ENABLED=true

# -----------------------------------------------------------------------------
# Monitoring
# -----------------------------------------------------------------------------
METRICS_ENABLED=true
METRICS_PORT=9100
METRICS_PATH=/metrics
PROMETHEUS_ENABLED=true
SENTRY_DSN=change_me_in_production

# -----------------------------------------------------------------------------
# Health Check
# -----------------------------------------------------------------------------
HEALTH_CHECK_TIMEOUT=5000
HEALTH_CHECK_DATABASE_ENABLED=true
HEALTH_CHECK_S3_ENABLED=true

# -----------------------------------------------------------------------------
# Graceful Shutdown
# -----------------------------------------------------------------------------
SHUTDOWN_TIMEOUT_SECONDS=30
