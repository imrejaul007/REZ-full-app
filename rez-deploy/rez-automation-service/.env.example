# =============================================================================
# REZ Automation Service - Environment Variables
# =============================================================================

NODE_ENV=production
PORT=3004
APP_NAME=rez-automation-service
APP_VERSION=1.0.0
TZ=UTC

# -----------------------------------------------------------------------------
# Logging
# -----------------------------------------------------------------------------
LOG_LEVEL=info
LOG_FORMAT=json
LOG_OUTPUT_DIR=/var/log/rez

# -----------------------------------------------------------------------------
# Database - PostgreSQL
# -----------------------------------------------------------------------------
DATABASE_HOST=postgres-primary.internal
DATABASE_PORT=5432
DATABASE_NAME=rez_automation
DATABASE_USERNAME=rez_automation_user
DATABASE_PASSWORD=change_me_in_production
DATABASE_SSL=true

# -----------------------------------------------------------------------------
# Redis
# -----------------------------------------------------------------------------
REDIS_HOST=redis.internal
REDIS_PORT=6379
REDIS_PASSWORD=change_me_in_production
REDIS_DB=4
REDIS_KEY_PREFIX=rez:automation:

# -----------------------------------------------------------------------------
# Message Queue - BullMQ
# -----------------------------------------------------------------------------
REDIS_BULLMQ_HOST=redis.internal
REDIS_BULLMQ_PORT=6379
REDIS_BULLMQ_PASSWORD=change_me_in_production
REDIS_BULLMQ_DB=1
BULLMQ_CONCURRENCY=5
BULLMQ_MAX_RETRY_ATTEMPTS=3
BULLMQ_RETRY_DELAY=5000

# -----------------------------------------------------------------------------
# External Services
# -----------------------------------------------------------------------------
SENDGRID_API_KEY=change_me_in_production
TWILIO_ACCOUNT_SID=change_me_in_production
TWILIO_AUTH_TOKEN=change_me_in_production
TWILIO_PHONE_NUMBER=change_me_in_production

# -----------------------------------------------------------------------------
# Security
# -----------------------------------------------------------------------------
JWT_SECRET=change_me_in_production_min_32_chars
ENCRYPTION_KEY=change_me_in_production_32_chars
WEBHOOK_SECRET=change_me_in_production

# -----------------------------------------------------------------------------
# Automation Configuration
# -----------------------------------------------------------------------------
AUTOMATION_SCHEDULER_ENABLED=true
AUTOMATION_MAX_CONCURRENT_JOBS=50
AUTOMATION_JOB_TIMEOUT_SECONDS=300
AUTOMATION_TRIGGER_COOLDOWN_MINUTES=5

# -----------------------------------------------------------------------------
# Monitoring
# -----------------------------------------------------------------------------
METRICS_ENABLED=true
METRICS_PORT=9094
METRICS_PATH=/metrics
PROMETHEUS_ENABLED=true
SENTRY_DSN=change_me_in_production

# -----------------------------------------------------------------------------
# Health Check
# -----------------------------------------------------------------------------
HEALTH_CHECK_TIMEOUT=5000
HEALTH_CHECK_DATABASE_ENABLED=true
HEALTH_CHECK_REDIS_ENABLED=true

# -----------------------------------------------------------------------------
# Graceful Shutdown
# -----------------------------------------------------------------------------
SHUTDOWN_TIMEOUT_SECONDS=30
