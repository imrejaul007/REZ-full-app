# Dependencies
node_modules
npm-debug.log
yarn-error.log

# Environment files (NEVER include in Docker image)
.env
.env.*
!.env.example

# Security — Firebase service account must NEVER be baked into the image
firebase-service-account.json

# Version control
.git
.gitignore
.gitattributes

# Documentation
README.md
*.md
docs/

# IDE
.vscode
.idea
*.swp
*.swo

# Coverage and testing
coverage
*.test.ts
*.spec.ts
__tests__
test
tests
load-tests
artillery-tests
jest.config.*

# Logs
logs
*.log

# OS files
.DS_Store
Thumbs.db

# Temporary files
uploads/temp
tmp/
temp/

# Build artifacts (we build inside container)
dist

# CI/CD
.github
.gitlab-ci.yml
.travis.yml

# Config files not needed in production (tsconfig.json MUST stay — needed for tsc build)
.eslintrc.*
.prettierrc
docker-compose.yml
docker-compose.*.yml
Dockerfile
.dockerignore

# Security - SSL certificates mounted at runtime
nginx/ssl

# Monitoring configs (mounted separately)
monitoring/

# Kubernetes manifests (not needed inside image)
k8s/

# Grafana dashboards (provisioned separately)
dashboards/

# Scripts not needed in container
scripts/
src/scripts/
src/seeds/

# Test files and test-related directories
tests/
load-tests/

# Security reports
security-reports/

# Backup files
*.backup
*.bak
**/*.backup
**/*.bak

# Uploaded files (mounted via volume at runtime)
uploads/
