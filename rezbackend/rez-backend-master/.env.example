# ─── Database ────────────────────────────────────────────────────────────────
MONGODB_URI=mongodb://localhost:27017/rez

# ─── Redis (single-node) ─────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ─── Redis Sentinel (optional — leave blank to use single-node REDIS_URL) ────
REDIS_SENTINEL_HOSTS=
REDIS_SENTINEL_NAME=mymaster
REDIS_PASSWORD=

# ─── JWT Secrets (min 32 chars each, ALL required) ───────────────────────────
JWT_SECRET=change-me-min-32-characters-long!!
JWT_REFRESH_SECRET=change-me-refresh-min-32-chars!!
JWT_MERCHANT_SECRET=change-me-merchant-min-32-chars!
JWT_ADMIN_SECRET=change-me-admin-min-32-chars!!!!

# ─── OTP Security (required) ─────────────────────────────────────────────────
OTP_HMAC_SECRET=change-me-otp-hmac-min-32-chars!!

# ─── Inter-service Auth (required in production) ─────────────────────────────
INTERNAL_SERVICE_TOKEN=change-me-internal-service-token

# ─── Razorpay ────────────────────────────────────────────────────────────────
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxx
RAZORPAY_KEY_SECRET=xxxxxxxxxxxxxxxxxxxx
RAZORPAY_WEBHOOK_SECRET=xxxxxxxxxxxxxxxxxxxx

# ─── Coin Economics ──────────────────────────────────────────────────────────
COIN_TO_RUPEE_RATE=0.50

# ─── Cashback ────────────────────────────────────────────────────────────────
CASHBACK_REDIS_REQUIRED=true

# ─── Merchant Payouts ────────────────────────────────────────────────────────
MERCHANT_PAYOUT_THRESHOLD_INR=100

# ─── Alerts (optional) ───────────────────────────────────────────────────────
SLACK_OPS_WEBHOOK_URL=

# ─── Observability ───────────────────────────────────────────────────────────
OTEL_ENABLED=false
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318/v1/traces
SERVICE_NAME=rez-backend

# ─── App ─────────────────────────────────────────────────────────────────────
NODE_ENV=development
FRONTEND_URL=http://localhost:3000
PORT=5000

# ─── Table Namespace Security (WebSocket /table authentication) ───────────────
# Required: JWT secret for short-lived table tokens (customer waiter calls)
TABLE_TOKEN_SECRET=change-me-table-token-min-32-chars!!

# Optional: hCaptcha configuration for CAPTCHA verification on /table namespace
# If not configured, only TABLE_TOKEN_SECRET authentication is used
CAPTCHA_SECRET_KEY=
CAPTCHA_SITE_KEY=

# ─── WebSocket Security ──────────────────────────────────────────────────────
# Maximum concurrent Socket.IO connections (default: 5000)
MAX_SOCKET_CONNECTIONS=5000
