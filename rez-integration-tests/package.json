{
  "name": "rez-integration-tests",
  "version": "1.0.0",
  "description": "Comprehensive integration tests for all REZ microservices",
  "scripts": {
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "test:ci": "jest --ci --runInBand --forceExit",
    "test:services": "jest --testPathPattern",
    "test:delivery": "jest --testPathPattern=delivery",
    "test:analytics": "jest --testPathPattern=analytics",
    "test:payment": "jest --testPathPattern=payment",
    "test:journey": "jest --testPathPattern=journey",
    "test:automation": "jest --testPathPattern=automation",
    "test:gdpr": "jest --testPathPattern=gdpr",
    "test:validation": "jest --testPathPattern=validation",
    "test:cohort": "jest --testPathPattern=cohort",
    "test:currency": "jest --testPathPattern=currency",
    "test:invoice": "jest --testPathPattern=invoice",
    "test:menu": "jest --testPathPattern=menu",
    "test:refund": "jest --testPathPattern=refund",
    "test:tracking": "jest --testPathPattern=tracking"
  },
  "dependencies": {
    "@types/jest": "^29.5.12",
    "@types/node": "^20.11.0",
    "@types/supertest": "^6.0.2",
    "jest": "^29.7.0",
    "supertest": "^6.3.4",
    "ts-jest": "^29.1.2",
    "typescript": "^5.3.3"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
