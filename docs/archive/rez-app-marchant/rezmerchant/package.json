{
  "name": "merchant-app",
  "version": "1.0.0",
  "main": "index.ts",
  "scripts": {
    "start": "expo start --port 8082",
    "start:clear": "node scripts/clear-cache.js && expo start --port 8082",
    "clear-cache": "node scripts/clear-cache.js",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web --port 8082",
    "build": "expo export",
    "build:web": "expo export --platform web",
    "eas:configure": "eas build:configure",
    "build:dev:ios": "eas build --platform ios --profile development",
    "build:dev:android": "eas build --platform android --profile development",
    "build:preview:ios": "eas build --platform ios --profile preview",
    "build:preview:android": "eas build --platform android --profile preview",
    "build:prod:ios": "eas build --platform ios --profile production",
    "build:prod:android": "eas build --platform android --profile production",
    "build:prod:all": "eas build --platform all --profile production",
    "submit:ios": "eas submit --platform ios --profile production",
    "submit:android": "eas submit --platform android --profile production",
    "prepare": "husky",
    "test": "jest --no-coverage",
    "test:coverage": "jest --coverage",
    "test:watch": "jest --watch --no-coverage",
    "format": "prettier --write 'app/**/*.ts' 'app/**/*.tsx'"
  },
  "dependencies": {
    "@expo/metro-runtime": "~5.0.5",
    "@expo/vector-icons": "^14.1.0",
    "@hookform/resolvers": "4.1.0",
    "@rez/shared": "git+https://github.com/imrejaul007/rez-shared.git#60ce7afc27caa2ac491287a7d309f9e69c20edaa",
    "@react-native-async-storage/async-storage": "2.1.2",
    "@react-native-community/datetimepicker": "8.4.1",
    "@react-native-community/netinfo": "^11.4.1",
    "@react-native-community/slider": "4.5.6",
    "@react-navigation/bottom-tabs": "^7.3.10",
    "@react-navigation/native": "^7.1.6",
    "@sentry/react-native": "^5.22.0",
    "@shopify/flash-list": "^2.3.0",
    "@tanstack/react-query": "^5.85.3",
    "@types/react": "~19.0.10",
    "axios": "^1.11.0",
    "babel-plugin-module-resolver": "^5.0.2",
    "date-fns": "^4.1.0",
    "expo": "~53.0.26",
    "expo-av": "~15.1.7",
    "expo-camera": "~16.1.11",
    "expo-constants": "~17.1.8",
    "expo-document-picker": "~13.1.6",
    "expo-file-system": "~17.0.1",
    "expo-font": "~13.3.2",
    "expo-haptics": "~14.1.4",
    "expo-image": "~2.4.1",
    "expo-image-picker": "~16.1.4",
    "expo-linear-gradient": "~14.1.5",
    "expo-linking": "~7.1.7",
    "expo-local-authentication": "~16.0.5",
    "expo-location": "~18.1.6",
    "expo-media-library": "~17.1.7",
    "expo-notifications": "~0.31.5",
    "expo-print": "~14.1.4",
    "expo-router": "~5.1.11",
    "expo-secure-store": "~14.2.4",
    "expo-sharing": "~13.1.5",
    "expo-sqlite": "^55.0.11",
    "expo-status-bar": "~2.2.3",
    "expo-store-review": "~8.1.5",
    "expo-updates": "~0.26.0",
    "expo-web-browser": "~14.2.0",
    "jsqr": "^1.4.0",
    "memoize-one": "^6.0.0",
    "react": "19.0.0",
    "react-dom": "19.0.0",
    "react-hook-form": "^7.66.0",
    "react-native": "0.79.6",
    "react-native-animatable": "^1.4.0",
    "react-native-draggable-flatlist": "^4.0.3",
    "react-native-gesture-handler": "~2.24.0",
    "react-native-get-random-values": "^1.1.0",
    "react-native-qrcode-svg": "^6.3.0",
    "react-native-razorpay": "^2.2.7",
    "react-native-reanimated": "~3.17.4",
    "react-native-safe-area-context": "5.4.0",
    "react-native-screens": "~4.11.1",
    "react-native-svg": "^15.0.0",
    "react-native-toast-message": "^2.3.3",
    "react-native-web": "^0.20.0",
    "react-native-worklets-core": "^1.6.2",
    "socket.io-client": "^4.8.1",
    "tslib": "^2.8.1",
    "uuid": "^13.0.0",
    "victory-native": "^37.3.0",
    "zod": "^4.1.12"
  },
  "devDependencies": {
    "@babel/core": "^7.25.2",
    "@types/detox": "^17.14.3",
    "@types/jest": "29.5.14",
    "@types/react": "~19.0.10",
    "@typescript-eslint/eslint-plugin": "^8.58.0",
    "@typescript-eslint/parser": "^8.58.0",
    "buffer": "^6.0.3",
    "crypto-browserify": "^3.12.1",
    "eslint": "^9.39.4",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "husky": "^9.0.11",
    "lint-staged": "^15.2.2",
    "prettier": "^3.2.5",
    "process": "^0.11.10",
    "stream-browserify": "^3.0.0",
    "typescript": "~5.8.3",
    "util": "^0.12.5"
  },
  "private": true,
  "lint-staged": {
    "app/**/*.ts": [
      "prettier --write"
    ],
    "app/**/*.tsx": [
      "prettier --write"
    ]
  }
