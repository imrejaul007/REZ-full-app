# Service Configuration
NODE_ENV=production
PORT=4010

# MongoDB Configuration
MONGODB_URI=mongodb://localhost:27017/rez-loyalty-monitoring
MONGODB_COLLECTION_METRICS=metric_snapshots
MONGODB_COLLECTION_ALERTS=alerts

# Redis Configuration
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_KEY_PREFIX=rez:loyalty:monitoring:

# Loyalty Service URLs
PROFILE_AGGREGATOR_URL=http://localhost:4025
STREAK_SERVICE_URL=http://localhost:4026
CROSS_MERCHANT_URL=http://localhost:4027
SCORE_SERVICE_URL=http://localhost:4028
KARMA_BRIDGE_URL=http://localhost:4029

# Alert Configuration
ALERT_ERROR_RATE_THRESHOLD=5
ALERT_LATENCY_THRESHOLD_MS=2000
ALERT_CACHE_MISS_THRESHOLD=50
ALERT_CHECK_INTERVAL_MS=30000
ALERT_RETENTION_DAYS=30

# Metrics Collection
METRICS_COLLECTION_INTERVAL_MS=10000
METRICS_HISTORY_RETENTION_DAYS=7

# Sentry Configuration (optional)
SENTRY_DSN=

# Logging
LOG_LEVEL=info
