# Environment Variables for rez-search-service
# Copy this file to .env and fill in real values
# Generate secrets with: openssl rand -base64 64

NODE_ENV=development
SERVICE_NAME=rez-search-service
PORT=4006
LOG_LEVEL=info

# Database [REQUIRED]
# Generate credentials: openssl rand -base64 24
MONGO_INITDB_ROOT_USERNAME=rez_admin
MONGO_INITDB_ROOT_PASSWORD=change-me-generate-with-openssl-rand-base64-24
MONGODB_URI=mongodb://rez_admin:password@localhost:27017/rez-search?authSource=admin

# Cache [REQUIRED]
# Generate password: openssl rand -hex 32
REDIS_PASSWORD=change-me-generate-with-openssl-rand-hex-32
# For authenticated Redis: redis://:password@localhost:6379
REDIS_URL=redis://:change-me-generate-with-openssl-rand-hex-32@localhost:6379
JWT_SECRET=change-me-generate-with-openssl-rand-base64-64
CORS_ORIGIN=http://localhost:3000
SENTRY_DSN=
SENTRY_ENVIRONMENT=development
SENTRY_TRACES_SAMPLE_RATE=0.1
# TRUST_PROXY — set to 'true' only when behind a trusted proxy (nginx, Cloudflare, ALB)
# that sanitizes X-Forwarded-For headers. Defaults to false (safe — uses socket IP).
# WARNING: Setting to 'true' without a trusted proxy enables IP spoofing attacks on the
# rate limiter. See SEA-002 and src/config/server.ts for full rationale.
TRUST_PROXY=false
# RTMN Commerce Memory — intent capture endpoint (fire-and-forget)
INTENT_CAPTURE_URL=https://rez-intent-graph.onrender.com
# Internal service key — must match INTENT_CAPTURE_URL server config
INTERNAL_SERVICE_TOKEN=change-me-generate-with-openssl-rand-base64-64
