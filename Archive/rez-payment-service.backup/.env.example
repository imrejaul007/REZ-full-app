# ===================================================================
# rez-payment-service Environment Configuration
# ===================================================================
# Copy this file to .env and fill in real values.
# REQUIRED: All vars marked [REQUIRED] must be set before startup
# OPTIONAL: Vars marked [OPTIONAL] have sensible defaults
# Generate secrets: openssl rand -base64 64 (for 64-char secrets)
# ===================================================================

# === Core Service Config [REQUIRED] ===
NODE_ENV=development
PORT=4001
HEALTH_PORT=4101
SERVICE_NAME=rez-payment-service
LOG_LEVEL=info

# === Database [REQUIRED] ===
MONGODB_URI=mongodb://localhost:27017/rez-payment

# === Cache [REQUIRED] ===
REDIS_URL=redis://localhost:6379
REDIS_PASSWORD=
REDIS_SENTINEL_HOSTS=
REDIS_SENTINEL_NAME=mymaster

# === Authentication [REQUIRED] ===
# Generate with: openssl rand -base64 64
JWT_SECRET=change-me-generate-with-openssl-rand-base64-64
JWT_MERCHANT_SECRET=change-me-generate-with-openssl-rand-base64-64

# === Internal Service Auth [REQUIRED] ===
# One of the following MUST be set:
# - INTERNAL_SERVICE_TOKENS_JSON (preferred): {"service-name": "token"}
# - INTERNAL_SERVICE_TOKEN (legacy fallback)
INTERNAL_SERVICE_TOKENS_JSON={"payment-service": "change-me-generate-with-openssl-rand-base64-64"}
# INTERNAL_SERVICE_TOKEN=change-me-generate-with-openssl-rand-base64-32

# === Razorpay Payment Gateway [OPTIONAL] ===
# If not set, Razorpay payments will be disabled at startup (warning logged)
RAZORPAY_KEY_ID=rzp_test_XXXXXXXXXXXX
RAZORPAY_KEY_SECRET=change-me-get-from-razorpay-dashboard
RAZORPAY_WEBHOOK_SECRET=change-me-get-from-razorpay-dashboard
RAZORPAY_CURRENCY=INR

# === Service-to-Service Integration [OPTIONAL] ===
WALLET_SERVICE_URL=http://localhost:3010/api
MONOLITH_URL=http://localhost:3000
INTERNAL_WEBHOOK_SECRET=change-me-generate-with-openssl-rand-base64-64
NBFC_PARTNER=

# === CORS [REQUIRED] ===
CORS_ORIGIN=http://localhost:3000,http://localhost:3001

# === Observability [OPTIONAL] ===
SENTRY_DSN=
SENTRY_ENVIRONMENT=development
SENTRY_TRACES_SAMPLE_RATE=0.1
