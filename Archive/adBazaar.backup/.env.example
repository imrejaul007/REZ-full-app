# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://xxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# Razorpay
RAZORPAY_KEY_ID=rzp_live_xxx
RAZORPAY_KEY_SECRET=xxx
NEXT_PUBLIC_RAZORPAY_KEY_ID=rzp_live_xxx
# Razorpay payout virtual account number (for disbursements)
RAZORPAY_PAYOUT_ACCOUNT_NUMBER=va_xxx

# Email (Resend)
RESEND_API_KEY=re_xxx
EMAIL_FROM=noreply@adbazaar.in

# Google Maps
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=AIza...

# REZ Integration
REZ_API_BASE_URL=https://api.rezapp.com/api
REZ_INTERNAL_KEY=your_rez_internal_service_token

# REZ Ads Service — digital ad campaigns
REZ_ADS_SERVICE_URL=https://rez-ads-service.onrender.com
ADBAZAAR_INTERNAL_KEY=generate_with_openssl_rand_hex_32

# REZ Marketing Service — broadcasts, audience targeting
REZ_MARKETING_SERVICE_URL=https://rez-marketing-service.onrender.com

# REZ Intent Graph — user intent capture
REZ_INTENT_CAPTURE_URL=https://rez-intent-graph.onrender.com

# REZ Wallet Service — for fetching user wallet balances
# Get balance via: GET /internal/balance/{userId} with x-internal-token header
REZ_WALLET_SERVICE_URL=https://rez-wallet-service.onrender.com

# REZ Payment Service — for routing payments through canonical payment service
# Replace direct Razorpay calls with: REZ_PAYMENT_SERVICE_URL/api/payments/*
REZ_PAYMENT_SERVICE_URL=https://rez-payment-service.onrender.com

# ReZ Mind Intent Capture (AdBazaar)
NEXT_PUBLIC_INTENT_CAPTURE_URL=https://rez-intent-graph.onrender.com

# REZ OAuth2 (Partner SSO)
REZ_AUTH_SERVICE_URL=https://rez-auth-service.onrender.com
REZ_OAUTH_CLIENT_ID=adbazaar
REZ_OAUTH_CLIENT_SECRET=generate_with_openssl_rand_hex_32
REZ_OAUTH_REDIRECT_URI=https://ad-bazaar.vercel.app/api/auth/rez-callback

# Webhooks
ADBAZAAR_WEBHOOK_SECRET=generate_with_openssl_rand_hex_32

# App
NEXT_PUBLIC_APP_URL=https://ad-bazaar.vercel.app
# REZ app Play Store URL fallback (for mobile deep links)
NEXT_PUBLIC_REZ_PLAY_STORE_URL=https://play.google.com/store/apps/details?id=com.rez.money

# Cron (generate a random secret, add to Vercel cron config)
CRON_SECRET=generate_with_openssl_rand_hex_32

# Security
# Comma-separated list of trusted proxy IPs (e.g., Vercel edge IPs)
# Leave empty to only trust x-real-ip (recommended for Vercel/serverless)
TRUSTED_PROXY_IPS=

# Internal service authentication (for Rez platform integration)
ADBAZAAR_INTERNAL_KEY=generate_with_openssl_rand_hex_32

# Upstash Redis (for durable rate limiting - requires Upstash account)
# Get credentials at: https://console.upstash.com
# If not configured, falls back to in-memory rate limiting (resets on cold start)
UPSTASH_REDIS_REST_URL=https://xxx.upstash.io
UPSTASH_REDIS_REST_TOKEN=xxx

# 2FA / TOTP (for admin accounts)
TOTP_SECRET_KEY=generate_with_openssl_rand_base32_32

# Twilio SMS (for OTP and notifications)
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_PHONE_NUMBER=+1234567890

# OneSignal (for push notifications)
ONESIGNAL_APP_ID=your_onesignal_app_id
ONESIGNAL_API_KEY=your_onesignal_api_key

# Sentry Error Monitoring (optional - requires Sentry account)
# Get DSN at: https://sentry.io/settings/your-org/projects/your-project/keys
SENTRY_DSN=https://xxx@sentry.io/xxx
