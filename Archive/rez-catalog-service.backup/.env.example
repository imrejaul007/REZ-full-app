# ===================================================================
# rez-catalog-service Environment Configuration
# ===================================================================
# Copy this file to .env and fill in real values.
# REQUIRED: All vars marked [REQUIRED] must be set before startup
# OPTIONAL: Vars marked [OPTIONAL] have sensible defaults
# ===================================================================

# === Core Service Config [REQUIRED] ===
NODE_ENV=development
PORT=3005
HEALTH_PORT=0
SERVICE_NAME=rez-catalog-service
LOG_LEVEL=info

# === Database [REQUIRED] ===
MONGODB_URI=mongodb://localhost:27017/rez-catalog
MONGODB_QUERY_TIMEOUT_MS=30000

# === Cache [REQUIRED] ===
REDIS_URL=redis://localhost:6379
REDIS_TLS=false

# === Internal Service Auth [REQUIRED] ===
# One of the following MUST be set:
# - INTERNAL_SERVICE_TOKENS_JSON (preferred): {"service-name": "token"}
# - INTERNAL_SERVICE_TOKEN (legacy fallback)
INTERNAL_SERVICE_TOKENS_JSON={"catalog-service": "change-me-generate-with-openssl-rand-base64-64"}
# INTERNAL_SERVICE_TOKEN=dev-internal-token-change-in-production

# === CORS [REQUIRED] ===
CORS_ORIGIN=http://localhost:3000,http://localhost:3001

# === Observability [OPTIONAL] ===
SENTRY_DSN=
