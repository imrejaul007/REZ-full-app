# ===================================================================
# rez-wallet-service Environment Configuration
# ===================================================================
# Copy this file to .env and fill in real values.
# REQUIRED: All vars marked [REQUIRED] must be set before startup
# OPTIONAL: Vars marked [OPTIONAL] have sensible defaults
# ===================================================================

# === Core Service Config [REQUIRED] ===
NODE_ENV=development
PORT=3010
HEALTH_PORT=0
SERVICE_NAME=rez-wallet-service
LOG_LEVEL=info

# === Database [REQUIRED] ===
# Generate credentials: openssl rand -base64 24
MONGO_INITDB_ROOT_USERNAME=rez_admin
MONGO_INITDB_ROOT_PASSWORD=change-me-generate-with-openssl-rand-base64-24
MONGODB_URI=mongodb://rez_admin:password@localhost:27017/rez-wallet?authSource=admin

# === Cache [REQUIRED] ===
# Generate password: openssl rand -hex 32
REDIS_PASSWORD=change-me-generate-with-openssl-rand-hex-32
# For authenticated Redis: redis://:password@localhost:6379
REDIS_URL=redis://:change-me-generate-with-openssl-rand-hex-32@localhost:6379
REDIS_TLS=false

# === Authentication [REQUIRED] ===
JWT_SECRET=change-me-generate-with-openssl-rand-base64-64

# === Internal Service Auth [REQUIRED] ===
# One of the following MUST be set:
# - INTERNAL_SERVICE_TOKENS_JSON (preferred): {"service-name": "token"}
# - INTERNAL_SERVICE_TOKEN (legacy fallback)
INTERNAL_SERVICE_TOKENS_JSON={"wallet-service": "change-me-generate-with-openssl-rand-base64-64"}
# INTERNAL_SERVICE_TOKEN=dev-internal-token-change-in-production

# === CORS [REQUIRED] ===
CORS_ORIGIN=http://localhost:3000,http://localhost:3001

# === Event Bus (Redis Streams) [OPTIONAL] ===
EVENT_BUS_ENABLED=true
EVENT_STREAM_NAME=rez:events

# === Observability [OPTIONAL] ===
SENTRY_DSN=

# === Coin Minting Caps [OPTIONAL] ===
# C-05 FIX: Limits on coin minting to prevent inflation.
# Set to 0 to disable a specific cap.
# Defaults: DAILY_COIN_CAP=1000, WEEKLY_COIN_CAP=5000, LIFETIME_COIN_CAP=100000
DAILY_COIN_CAP=1000
WEEKLY_COIN_CAP=5000
LIFETIME_COIN_CAP=100000

# === AML Compliance Limits [OPTIONAL] ===
# C-01 FIX: Anti-Money Laundering thresholds (in paise)
# CTR: Cash Transaction Report triggered when transactions exceed CASH_THRESHOLD
AML_CASH_THRESHOLD=10000000
# STR: Suspicious Transaction Report threshold
AML_STR_THRESHOLD=5000000
# Velocity limits per user
AML_DAILY_LIMIT=50000000
AML_WEEKLY_LIMIT=200000000
# Round-trip detection
AML_ROUND_TRIP_THRESHOLD=100000
AML_ROUND_TRIP_WINDOW_HOURS=24
# Transaction frequency limits
AML_TX_COUNT_DAILY=50
AML_TX_COUNT_HOURLY=10
# Large transaction threshold
AML_LARGE_TRANSACTION_THRESHOLD=1000000
