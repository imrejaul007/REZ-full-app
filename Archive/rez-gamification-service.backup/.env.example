# Redis
REDIS_URL=redis://localhost:6379
REDIS_TLS=false

# MongoDB
MONGODB_URI=mongodb://localhost:27017/rez

# Service
NODE_ENV=development
PORT=3004

# Sentry Error Tracking
SENTRY_DSN=https://your-sentry-dsn@sentry.io/project
LOG_LEVEL=info

# Internal Auth (for service-to-service calls)
INTERNAL_SERVICE_TOKEN=dev-internal-token-change-in-production

# RTMN Commerce Memory — intent capture endpoint (fire-and-forget)
INTENT_CAPTURE_URL=https://rez-intent-graph.onrender.com

# Wallet Service — for coin credits (production)
REZ_WALLET_SERVICE_URL=https://rez-wallet-service.onrender.com

# Marketing Service — for campaigns and vouchers (production)
REZ_MARKETING_SERVICE_URL=https://rez-marketing-service.onrender.com

# Notification Events Service — for multi-channel notifications (production)
REZ_NOTIFICATION_SERVICE_URL=https://rez-notification-events.onrender.com

# Push Service — for direct push notifications (production)
REZ_PUSH_SERVICE_URL=https://rez-push-service.onrender.com
