{
  "compilerOptions": {
    "target": "ES2020",
    "module": "commonjs",
    "lib": ["ES2020"],
    "outDir": "./dist",
    "rootDir": "./src",
    "strict": false,
    "noImplicitAny": false,
    "noEmitOnError": false,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "declaration": false,
    "sourceMap": true,
    "types": ["node"],
    "typeRoots": ["./node_modules/@types"],
    "moduleResolution": "node",
    "baseUrl": ".",
    "paths": {
      "@rez/shared": ["../packages/rez-shared/dist"],
      "@rez/shared/*": ["../packages/rez-shared/dist/*"],
      "@rez/shared-types": ["../packages/shared-types/dist"],
      "@rez/shared-types/*": ["../packages/shared-types/dist/*"]
    }
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules", "dist", "src/__tests__", "**/*.test.ts", "**/*.spec.ts", "src/jobs/**"]
}
