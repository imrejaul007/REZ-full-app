# REZ Support Copilot Environment Variables
# Copy this file to .env and fill in your values

# Service
SERVICE_NAME=rez-support-copilot
LOG_LEVEL=info

# Server Configuration
PORT=4033

# MongoDB Connection
MONGODB_URI=mongodb://localhost:27017/rez-support

# REZ Intelligence Hub (AI Processing)
REZ_MIND_URL=http://localhost:4008

# REZ Event Platform (Logging)
REZ_EVENT_PLATFORM_URL=https://REZ-event-platform.onrender.com

# Local Services (for development)
REZ_ORDER_SERVICE_URL=http://localhost:4012
REZ_BOOKING_SERVICE_URL=http://localhost:4013

# Production Services (onrender.com)
SEARCH_SERVICE_URL=https://rez-search-service.onrender.com
ORDER_SERVICE_URL=https://rez-order-service.onrender.com
KNOWLEDGE_BASE_URL=https://rez-knowledge-base-service.onrender.com

# User Intelligence Service (onrender.com)
USER_INTELLIGENCE_URL=https://REZ-user-intelligence.onrender.com

# Webhook Configuration
SUPPORT_COPILOT_WEBHOOK_SECRET=your-secure-webhook-secret
