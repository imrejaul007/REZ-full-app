# ===================================================================
# rez-order-service Environment Configuration
# ===================================================================
# Copy this file to .env and fill in real values.
# REQUIRED: All vars marked [REQUIRED] must be set before startup
# OPTIONAL: Vars marked [OPTIONAL] have sensible defaults
# ===================================================================

# === Core Service Config [REQUIRED] ===
NODE_ENV=development
PORT=4003
HEALTH_PORT=0
SERVICE_NAME=rez-order-service
LOG_LEVEL=info

# === Database [REQUIRED] ===
# Generate credentials: openssl rand -base64 24
MONGO_INITDB_ROOT_USERNAME=rez_admin
MONGO_INITDB_ROOT_PASSWORD=change-me-generate-with-openssl-rand-base64-24
MONGODB_URI=mongodb://rez_admin:password@localhost:27017/rez-order?authSource=admin

# === Cache [REQUIRED] ===
# Generate password: openssl rand -hex 32
REDIS_PASSWORD=change-me-generate-with-openssl-rand-hex-32
# For authenticated Redis: redis://:password@localhost:6379
REDIS_URL=redis://:change-me-generate-with-openssl-rand-hex-32@localhost:6379
REDIS_TLS=false

# === Authentication [REQUIRED] ===
JWT_SECRET=change-me-generate-with-openssl-rand-base64-64

# === Internal Service Auth [REQUIRED] ===
# One of the following MUST be set:
# - INTERNAL_SERVICE_TOKENS_JSON (preferred): {"service-name": "token"}
# - INTERNAL_SERVICE_TOKEN (legacy fallback)
INTERNAL_SERVICE_TOKENS_JSON={"order-service": "change-me-generate-with-openssl-rand-base64-64"}
# INTERNAL_SERVICE_TOKEN=dev-internal-token-change-in-production

# === CORS [REQUIRED] ===
CORS_ORIGIN=http://localhost:3000,http://localhost:3001

# === RTMN Commerce Memory [OPTIONAL] ===
INTENT_CAPTURE_URL=https://rez-intent-graph.onrender.com
# Internal service key — must match INTENT_CAPTURE_URL server config
INTERNAL_SERVICE_TOKEN=change-me-generate-with-openssl-rand-base64-64

# === Event Bus (Redis Streams) [OPTIONAL] ===
EVENT_BUS_ENABLED=true
EVENT_STREAM_NAME=rez:events

# === Observability [OPTIONAL] ===
SENTRY_DSN=

# === REZ-support-copilot Webhook [OPTIONAL] ===
SUPPORT_COPILOT_WEBHOOK_URL=https://REZ-support-copilot.onrender.com
