# Server Configuration
PORT=4028
NODE_ENV=development

# Email Configuration
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
EMAIL_FROM=Invoices <invoices@yourcompany.com>

# Company Details (for GST invoices)
COMPANY_NAME=Your Company Name
COMPANY_ADDRESS=Your Business Address
COMPANY_GSTIN=YOURGSTIN123456
COMPANY_PAN=AAACP1234C
COMPANY_EMAIL=contact@yourcompany.com
COMPANY_PHONE=+91-1234567890

# Invoice Settings
INVOICE_PREFIX=INV
INVOICE_DUE_DAYS=30
INVOICE_NUMBER_FORMAT=${PREFIX}-${YEAR}-${NUMBER}

# Reminder Settings
REMINDER_SCHEDULE=0 9 * * *
FIRST_REMINDER_DAYS=7
SECOND_REMINDER_DAYS=14
FINAL_REMINDER_DAYS=21

# Database
DB_PATH=./data/invoices.db
