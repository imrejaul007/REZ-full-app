# REZ Platform - Docker Environment Variables
# Copy this file to .env and fill in your values

# ============================================
# MONGODB (Required)
# ============================================
# Get from MongoDB Atlas - https://cloud.mongodb.com
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net

# ============================================
# REDIS (Required)
# ============================================
# Get from Redis Cloud - https://redis.com/cloud
REDIS_URL=redis://default:password@host:port

# ============================================
# SECURITY (Required - Change these!)
# ============================================
# Must be at least 32 characters
JWT_SECRET=your-super-secret-jwt-key-change-this-now

# ============================================
# CORS (Required)
# ============================================
CORS_ORIGIN=http://localhost:3000,https://rez.money

# ============================================
# PAYMENT GATEWAY (Optional - for production)
# ============================================
RAZORPAY_KEY_ID=your-razorpay-key-id
RAZORPAY_KEY_SECRET=your-razorpay-key-secret

# ============================================
# BBPS (Optional - for bill payments)
# ============================================
BBPS_MERCHANT_ID=your-merchant-id
BBPS_API_KEY=your-api-key

# ============================================
# E-INVOICE (Optional - for GST)
# ============================================
EINVOICE_USERNAME=your-username
EINVOICE_PASSWORD=your-password

# ============================================
# MONITORING (Optional)
# ============================================
SENTRY_DSN=https://xxxxx@sentry.io/xxxxx
