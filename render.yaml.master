# render.yaml.master - ReZ Ecosystem Master Render Configuration Template
# ================================================================
#
# This is the master template for all ReZ services deployed on Render.
# Copy this file to each service directory and customize as needed.
#
# Template Version: 1.0.0
# Last Updated: 2026-05-11
#
# ================================================================

# ---------------------------------------------------------------------------
# SERVICE CONFIGURATION
# ---------------------------------------------------------------------------
# Each service must define its own services array. This template shows all
# available options. Remove inapplicable options for your service.

services:
  # -------------------------------------------------------------------------
  # NODE.JS SERVICE EXAMPLE
  # -------------------------------------------------------------------------
  - type: web
    name: SERVICE_NAME
    env: node
    region: oregon
    plan: free

    # Build configuration
    buildCommand: npm ci && npm run build
    startCommand: npm start

    # Health check endpoint
    healthCheckPath: /health

    # Auto-scaling (optional)
    scaling:
      minInstances: 1
      maxInstances: 3
      targetMemoryPercent: 70
      targetCPUPercent: 80

    # Environment variables
    envVars:
      # Application settings
      - key: NODE_ENV
        value: production
      - key: PORT
        value: 3000
      - key: LOG_LEVEL
        value: info

      # Secrets (sync: false = managed in Render Dashboard)
      - key: DATABASE_URL
        sync: false
      - key: REDIS_URL
        sync: false
      - key: INTERNAL_API_KEY
        sync: false

      # Generated secrets (Render creates random values)
      - key: SESSION_SECRET
        generateValue: true

      # Service-specific configuration
      - key: SERVICE_CONFIG
        fromGroup: SERVICE_ENV_GROUP

    # Custom headers
    headers:
      - path: /*
        name: Security Headers
        value: |
          X-Content-Type-Options: nosniff
          X-Frame-Options: DENY
          X-XSS-Protection: 1; mode=block
          Referrer-Policy: strict-origin-when-cross-origin
          Content-Security-Policy: default-src 'self'

    # Number of build commands to cache (optional)
    cacheCommandTimeout: 600

  # -------------------------------------------------------------------------
  # DOCKER SERVICE EXAMPLE
  # -------------------------------------------------------------------------
  - type: web
    name: SERVICE_NAME_DOCKER
    runtime: docker
    dockerfilePath: ./Dockerfile

    region: oregon
    plan: starter

    healthCheckPath: /health
    port: 8080

    envVars:
      - key: NODE_ENV
        value: production
      - key: PORT
        value: 8080
      - key: DATABASE_URL
        sync: false
      - key: REDIS_URL
        sync: false

    scaling:
      minInstances: 1
      maxInstances: 5
      targetMemoryPercent: 60
      targetCPUPercent: 70

  # -------------------------------------------------------------------------
  # BACKGROUND WORKER EXAMPLE
  # -------------------------------------------------------------------------
  - type: worker
    name: SERVICE_NAME_WORKER
    env: node
    region: oregon
    plan: starter

    buildCommand: npm ci && npm run build
    startCommand: npm run worker

    envVars:
      - key: NODE_ENV
        value: production
      - key: REDIS_URL
        sync: false
      - key: JOB_QUEUE_URL
        sync: false

    scaling:
      minInstances: 1
      maxInstances: 3
      targetMemoryPercent: 80
      targetCPUPercent: 90

  # -------------------------------------------------------------------------
  # CRON JOB EXAMPLE
  # -------------------------------------------------------------------------
  - type: cron
    name: SERVICE_NAME_CRON
    env: node
    region: oregon
    plan: starter
    schedule: "0 * * * *"

    buildCommand: npm ci && npm run build
    startCommand: npm run cron

    envVars:
      - key: NODE_ENV
        value: production
      - key: DATABASE_URL
        sync: false

# ---------------------------------------------------------------------------
# DATABASE CONFIGURATION
# ---------------------------------------------------------------------------
# PostgreSQL Database
databases:
  - name: SERVICE_NAME-db
    plan: starter
    databaseName: service_name_db
    ipAllowList: []
    # postgresVersion: 15

  # PostgreSQL with auto-suspend disabled
  # - name: SERVICE_NAME-db-persistent
  #   plan: starter
  #   databaseName: service_name_db
  #   ipAllowList: []
  #   autoSuspendTimeout: -1

# ---------------------------------------------------------------------------
# KEY-VALUE STORE (Redis)
# ---------------------------------------------------------------------------
# Uncomment if your service needs Redis
# redis:
#   - name: SERVICE_NAME-redis
#     plan: starter
#     ipAllowList: []

# ---------------------------------------------------------------------------
# DISK VOLUMES
# ---------------------------------------------------------------------------
# Uncomment for persistent disk storage
# disks:
#   - name: SERVICE_NAME-storage
#     mountPath: /data
#     sizeGB: 10
#     plan: starter

# ---------------------------------------------------------------------------
# ENVIRONMENT GROUPS
# ---------------------------------------------------------------------------
# Environment groups allow sharing environment variables across services
# Create these in Render Dashboard > Environment Groups
#
# Groups to create in Render Dashboard:
#
# REZ_CORE_CONFIG:
#   - CORE_API_URL
#   - CORE_AUTH_TOKEN
#   - CORE_WEBHOOK_SECRET
#
# REZ_DATABASE_CONFIG:
#   - DATABASE_POOL_SIZE
#   - DATABASE_TIMEOUT
#
# REZ_REDIS_CONFIG:
#   - REDIS_MAX_RETRIES
#   - REDIS_RETRY_DELAY
#
# REZ_EXTERNAL_SERVICES:
#   - PAYMENT_GATEWAY_URL
#   - SMS_PROVIDER_URL
#   - EMAIL_PROVIDER_URL
#
# REZ_MONITORING:
#   - SENTRY_DSN
#   - DATADOG_API_KEY
#   - LOGDNA_KEY

