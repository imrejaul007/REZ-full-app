{
  "name": "@rez/monorepo",
  "version": "1.0.0",
  "private": true,
  "description": "ReZ Unified Services Monorepo - Turborepo-powered workspace",
  "workspaces": [
    "packages/*",
    "rez-*"
  ],
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "build:shared": "turbo run build --filter=@rez/shared --filter=@rez/shared-types",
    "test": "turbo run test",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "clean": "turbo run clean",
    "format": "turbo run format",
    "deploy": "turbo run deploy",
    "health": "bash scripts/health-all.sh",
    "deploy:all": "bash scripts/deploy-all.sh",
    "stop:all": "bash scripts/stop-all.sh"
  },
  "devDependencies": {
    "turbo": "^2.4.4",
    "typescript": "^5.3.0"
  },
  "engines": {
    "node": ">=20.0.0",
    "npm": ">=10.0.0"
  },
  "packageManager": "npm@10.0.0"
}
