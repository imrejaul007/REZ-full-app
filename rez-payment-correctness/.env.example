# Payment Correctness Service - Environment Variables
# Copy this file to .env and fill in the values

# =============================================================================
# REQUIRED VARIABLES
# =============================================================================

# Internal service token (REQUIRED)
INTERNAL_SERVICE_TOKEN=your-secure-random-token-here

# JSON map of service tokens
# Format: {"service-name": "token"}
INTERNAL_SERVICE_TOKENS_JSON={"payment-service":"token1","ledger-service":"token2"}

# =============================================================================
# OPTIONAL VARIABLES
# =============================================================================

# Port (defaults to 4020)
PORT=4020

# Redis URL (for distributed rate limiting)
REDIS_URL=redis://localhost:6379

# Node environment
NODE_ENV=development

# =============================================================================
# SECURITY NOTES
# =============================================================================
#
# 1. INTERNAL_SERVICE_TOKEN is REQUIRED
#
# 2. Use strong random tokens (minimum 32 characters)
#    Generate with: openssl rand -hex 32
#
# 3. Only trusted internal services should have tokens
#
