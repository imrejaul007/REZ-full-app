# ============================================================
# REZ Ecosystem - Environment Configuration Template
# ============================================================
# Copy this file to .env and fill in your values
# NEVER commit .env to version control
# UPDATED: May 10, 2026
# ============================================================

# === Node Environment ===
NODE_ENV=development
LOG_LEVEL=debug

# === Core Service Ports ===
PORT=3000
HEALTH_PORT=4000

# === MongoDB Configuration ===
MONGODB_URI=mongodb://localhost:27017
MONGODB_DB_NAME=rez_dev

# === Redis Configuration ===
REDIS_URL=redis://localhost:6379
REDIS_PASSWORD=

# === PostgreSQL Configuration ===
POSTGRES_USER=rez
POSTGRES_PASSWORD=<your_postgres_password>
POSTGRES_DB=rez_dev
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# === JWT & Authentication Secrets ===
# SECURITY: Generate secure random values (64+ characters)
# Use: openssl rand -base64 64
JWT_SECRET=<your_jwt_secret_64_chars_minimum>
JWT_REFRESH_SECRET=<your_jwt_refresh_secret_64_chars_minimum>
JWT_ADMIN_SECRET=<your_jwt_admin_secret_64_chars_minimum>
JWT_MERCHANT_SECRET=<your_jwt_merchant_secret_64_chars_minimum>
OTP_HMAC_SECRET=<your_otp_hmac_secret>
OTP_TOTP_ENCRYPTION_KEY=<your_totp_encryption_key_32_chars>

# === Bcrypt Configuration ===
BCRYPT_ROUNDS=10

# === CORS Configuration ===
# Comma-separated list of allowed origins (NO wildcards in production)
CORS_ORIGIN=http://localhost:3000,http://localhost:3001,http://localhost:4000,http://localhost:4002,http://localhost:4004,http://localhost:4005
ALLOWED_CORS_ORIGINS=https://reznow.app,https://admin.reznow.app,https://restauranthub.app
ALLOWED_WIDGET_ORIGINS=https://hotel.example.com,https://booking.example.com

# === SERVICE URLs (inter-service communication) ===
# Core Backend Services
AUTH_SERVICE_URL=http://localhost:4002
PAYMENT_SERVICE_URL=http://localhost:4001
ORDER_SERVICE_URL=http://localhost:3006
CATALOG_SERVICE_URL=http://localhost:3005
SEARCH_SERVICE_URL=http://localhost:4003
MERCHANT_SERVICE_URL=http://localhost:4005
WALLET_SERVICE_URL=http://localhost:4004
HOTEL_SERVICE_URL=http://localhost:4015
STAYOWN_SERVICE_URL=http://localhost:4016
BOOKING_SERVICE_URL=http://localhost:4020
NOTIFICATION_SERVICE_URL=http://localhost:4011
KARMA_SERVICE_URL=http://localhost:4011
GAMIFICATION_SERVICE_URL=http://localhost:3004
MARKETING_SERVICE_URL=http://localhost:4000
TRAVEL_SERVICE_URL=http://localhost:4007
PROFILE_SERVICE_URL=http://localhost:4016
FINANCE_SERVICE_URL=http://localhost:4006
AD_SERVICE_URL=http://localhost:4007

# API Gateway & AI Services
API_GATEWAY_URL=http://localhost:3001
INTENT_SERVICE_URL=http://localhost:4009
COPILOT_SERVICE_URL=http://localhost:4026
DECISION_SERVICE_URL=http://localhost:4027
AD_PLATFORM_SERVICE_URL=http://localhost:4028
MARKETING_AI_URL=http://localhost:4000
TARGETING_ENGINE_URL=http://localhost:3003
INTELLIGENCE_HUB_URL=http://localhost:4020
ACTION_ENGINE_URL=http://localhost:4009
PERSONALIZATION_ENGINE_URL=http://localhost:4017
USER_INTELLIGENCE_URL=http://localhost:3016

# Media & Events
MEDIA_EVENTS_URL=http://localhost:3015

# DOOH Service
DOOH_SERVICE_URL=http://localhost:4018

# ML Infrastructure
ML_FEATURE_STORE_URL=http://localhost:4100
ML_MODEL_REGISTRY_URL=http://localhost:4101
ML_TRAINING_DATA_URL=http://localhost:4102
ML_DATA_QUALITY_URL=http://localhost:4106

# Internal Service Token
# SECURITY: Generate a secure random token for inter-service communication
# Use: openssl rand -hex 32
INTERNAL_SERVICE_TOKEN=<your_internal_service_token>
INTERNAL_SERVICE_TOKENS_JSON=<your_service_tokens_json>

# === OAuth Configuration ===
OAUTH_GOOGLE_CLIENT_ID=<your_google_client_id>
OAUTH_GOOGLE_CLIENT_SECRET=<your_google_client_secret>
OAUTH_APPLE_CLIENT_ID=<your_apple_client_id>
OAUTH_APPLE_TEAM_ID=<your_apple_team_id>
OAUTH_APPLE_KEY_ID=<your_apple_key_id>
OAUTH_APPLE_PRIVATE_KEY_PATH=<path_to_your_apple_private_key>
APP_URL=http://localhost:3000

# === External APIs ===
MAKCORPS_ACCESS_TOKEN=<your_makcorps_token>
NEXTABIZZ_ACCESS_TOKEN=<your_nextabizz_token>
WEATHER_API_KEY=<your_weather_api_key>

# === Monitoring ===
SENTRY_DSN=<your_sentry_dsn>
OTEL_EXPORTER_OTLP_ENDPOINT=<your_otel_endpoint>
OTEL_SERVICE_NAME=rez-development
LOKI_URL=http://localhost:3100

# === Alerting ===
SLACK_WEBHOOK_URL=<your_slack_webhook_url>
PAGERDUTY_ROUTING_KEY=<your_pagerduty_key>
ALERT_EMAIL=alerts@rez.money

# === Feature Flags ===
ENABLE_FEATURE_FLAGS=true
FEATURE_FLAG_SERVICE_URL=http://localhost:4020

# === ML Services ===
MODEL_SERVER_URL=http://localhost:5000
FEATURE_STORE_URL=http://localhost:5001

# === App Check ===
# SECURITY: Generate a secure random secret
APP_CHECK_SECRET_KEY=<your_app_check_secret>

# === Encryption ===
# SECURITY: Generate a secure random key (64+ characters)
ENCRYPTION_KEY=<your_encryption_key_64_chars_minimum>

# === Payment Webhooks ===
# SECURITY: Get these from your payment provider dashboard
RAZORPAY_WEBHOOK_SECRET=<your_razorpay_webhook_secret>
STRIPE_WEBHOOK_SECRET=<your_stripe_webhook_secret>

# === WhatsApp Webhooks ===
# SECURITY: Get these from Meta Developer Console
WHATSAPP_WEBHOOK_VERIFY_TOKEN=<your_whatsapp_webhook_verify_token>
WHATSAPP_APP_SECRET=<your_whatsapp_app_secret>
WHATSAPP_API_URL=https://graph.facebook.com/v18.0
WHATSAPP_PHONE_NUMBER_ID=<your_whatsapp_phone_number_id>
WHATSAPP_ACCESS_TOKEN=<your_whatsapp_access_token>

# === MongoDB Advanced Configuration ===
MONGODB_AUTH_SOURCE=admin
MONGODB_USERNAME=<your_mongodb_username>
MONGODB_PASSWORD=<your_mongodb_password>
MONGODB_READ_PREFERENCE=primary

# === JWT Configuration ===
JWT_EXPIRES_IN=1h
JWT_REFRESH_TTL_HOURS=168
JWT_ADMIN_EXPIRES_IN=24h
JWT_MFA_SESSION_SECRET=<your_mfa_session_secret>

# === Corp Authentication ===
CORP_JWT_SECRET=<your_corp_jwt_secret>

# === Partner OAuth Configuration ===
# ReZ Now Partner
PARTNER_REZNOW_CLIENT_ID=<your_reznow_client_id>
PARTNER_REZNOW_CLIENT_SECRET=<your_reznow_client_secret>
PARTNER_REZNOW_REDIRECT_URI=http://localhost:3000/api/auth/callback

# Ad Bazaar Partner
PARTNER_ADBAZAAR_CLIENT_ID=<your_adbazaar_client_id>
PARTNER_ADBAZAAR_CLIENT_SECRET=<your_adbazaar_client_secret>
PARTNER_ADBAZAAR_REDIRECT_URI=http://localhost:3000/api/auth/callback

# Hotel Panel Partner
PARTNER_HOTEL_PANEL_CLIENT_ID=<your_hotel_panel_client_id>
PARTNER_HOTEL_PANEL_CLIENT_SECRET=<your_hotel_panel_client_secret>
PARTNER_HOTEL_PANEL_REDIRECT_URI=http://localhost:3000/api/auth/callback

# Hotel PMS Partner
PARTNER_HOTEL_PMS_CLIENT_ID=<your_hotel_pms_client_id>
PARTNER_HOTEL_PMS_CLIENT_SECRET=<your_hotel_pms_client_secret>
PARTNER_HOTEL_PMS_REDIRECT_URI=http://localhost:3000/api/auth/callback

# Rendez Partner
PARTNER_RENDEZ_CLIENT_ID=<your_rendez_client_id>
PARTNER_RENDEZ_CLIENT_SECRET=<your_rendez_client_secret>
PARTNER_RENDEZ_REDIRECT_URI=http://localhost:3000/api/auth/callback

# Nextabizz Partner
PARTNER_NEXTABIZZ_CLIENT_ID=<your_nextabizz_client_id>
PARTNER_NEXTABIZZ_CLIENT_SECRET=<your_nextabizz_client_secret>
PARTNER_NEXTABIZZ_REDIRECT_URI=http://localhost:3000/api/auth/callback

# OAuth Base URL
OAUTH_AUTHORIZE_BASE_URL=https://accounts.google.com/o/oauth2/v2/auth

# === Development Settings ===
EXPOSE_DEV_OTP=false
ALLOWED_INTERNAL_IPS=127.0.0.1,localhost

# === OpenTelemetry ===
OTEL_SERVICE_VERSION=1.0.0

# === Standardized Dependencies ===
# All services MUST use these versions to avoid conflicts
# zod: ^3.23.x (NOT v4)
# @sentry/node: ^7.120.x (NOT v8)
# helmet: ^7.1.x (NOT v8)
