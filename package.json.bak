{
  "name": "@rez/shared-types",
  "version": "2.0.0",
  "description": "Canonical TypeScript interfaces, zod schemas, FSM helpers, branded IDs, and runtime guards for all RuFlo/REZ services",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist",
    "README.md",
    "MIGRATION.md"
  ],
  "scripts": {
    "build": "tsc",
    "prepare": "npm run build",
    "watch": "tsc --watch",
    "clean": "rm -rf dist",
    "test": "jest --config tests/jest.config.js",
    "test:watch": "jest --config tests/jest.config.js --watch",
    "test:cov": "jest --config tests/jest.config.js --coverage",
    "test:unit": "jest --config tests/jest.config.js tests/unit",
    "test:integration": "jest --config tests/jest.config.js tests/integration",
    "publish:npm": "npm run build && npm publish --access public"
  },
  "keywords": [
    "types",
    "interfaces",
    "entities",
    "zod",
    "fsm",
    "branded-ids",
    "rez"
  ],
  "dependencies": {
    "zod": "^3.22.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^4.17.25",
    "@types/jest": "^30.0.0",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/mongoose": "^5.11.96",
    "@types/node": "^25.6.0",
    "axios": "^1.16.0",
    "jest": "^30.3.0",
    "js-yaml": "^4.1.1",
    "jsonwebtoken": "^9.0.3",
    "mongoose": "^9.6.1",
    "ts-jest": "^29.4.9",
    "turbo": "^2.9.10",
    "typescript": "^5.3.0",
    "vitest": "^4.1.5"
  },
  "peerDependencies": {
    "express": "^4.18.0"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./fsm": {
      "types": "./dist/fsm/index.d.ts",
      "default": "./dist/fsm/index.js"
    },
    "./guards": {
      "types": "./dist/guards/index.d.ts",
      "default": "./dist/guards/index.js"
    },
    "./branded": {
      "types": "./dist/branded/ids.d.ts",
      "default": "./dist/branded/ids.js"
    },
    "./validation": {
      "types": "./dist/validation/index.d.ts",
      "default": "./dist/validation/index.js"
    }
  }
}
