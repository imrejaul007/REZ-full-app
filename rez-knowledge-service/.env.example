# REZ Knowledge Service Environment Variables
# Unified User Knowledge Base Service - Single Source of Truth for ALL Apps

NODE_ENV=development
PORT=3003

# MongoDB Connection
MONGODB_URI=mongodb://localhost:27017/rez-knowledge

# Service Configuration
LOG_LEVEL=info
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# Signal Collection Settings
SIGNAL_COLLECTION_ENABLED=true
SIGNAL_DEFAULT_LIMIT=100
MAX_SIGNALS_PER_USER=10000
SIGNAL_RETENTION_DAYS=90

# CORS Origins (comma-separated)
CORS_ORIGINS=http://localhost:3000,http://localhost:8080,https://rez.money,https://admin.rez.money,https://merchant.rez.money

# JWT Secret for service-to-service auth
SERVICE_SECRET=your-service-secret-key

# ─── Connected App Service URLs ─────────────────────────────────────────────────
# URLs for signal collection from each app in the ecosystem

# StayOwn (Hotel Booking)
STAYOWN_SERVICE_URL=http://localhost:4001
STAYOWN_API_KEY=your-stayown-api-key

# REZ Consumer App (Main Consumer Service)
REZ_CONSUMER_SERVICE_URL=http://localhost:4002
REZ_CONSUMER_API_KEY=your-rez-consumer-api-key

# Rendez (Couples/Dating)
RENDEZ_SERVICE_URL=http://localhost:4003
RENDEZ_API_KEY=your-rendez-api-key

# Corpspark (Corporate Services)
CORPSPARK_SERVICE_URL=http://localhost:4004
CORPSPARK_API_KEY=your-corpspark-api-key

# Restaurant Service
RESTAURANT_SERVICE_URL=http://localhost:4005
RESTAURANT_API_KEY=your-restaurant-api-key

# Salon Service
SALON_SERVICE_URL=http://localhost:4006
SALON_API_KEY=your-salon-api-key

# Healthcare Service
HEALTHCARE_SERVICE_URL=http://localhost:4007
HEALTHCARE_API_KEY=your-healthcare-api-key
