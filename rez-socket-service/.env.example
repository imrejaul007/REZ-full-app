# =============================================================================
# rez-socket-service - Environment Variables Template
# =============================================================================
# SECURITY: This is a TEMPLATE. Copy to .env and fill in REAL values.
# NEVER commit .env files with actual secrets to version control.
# Generate secure secrets with: openssl rand -base64 32
# =============================================================================

# Server Configuration
PORT=3001
NODE_ENV=development

# =============================================================================
# SECURITY: CORS ORIGIN - REQUIRED (NO DEFAULT)
# =============================================================================
# Comma-separated list of allowed origins.
# EXAMPLES:
#   Development: http://localhost:3000,http://localhost:8080
#   Production:  https://app.rez.money,https://rez.money
# CRITICAL: Wildcard '*' is BLOCKED in production (NODE_ENV=production)
CORS_ORIGIN=http://localhost:3000,http://localhost:8080

# =============================================================================
# JWT SECRET - REQUIRED (NO DEFAULT)
# =============================================================================
# CRITICAL: Generate with: openssl rand -base64 32
# Used to authenticate WebSocket connections.
JWT_SECRET=REPLACE_WITH_SECURE_JWT_SECRET_44_BASE64_CHARS

# =============================================================================
# REDIS (Socket Adapter) - REQUIRED
# =============================================================================
# Generate password: openssl rand -hex 32
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=REPLACE_WITH_REDIS_PASSWORD
REDIS_DB=0

# =============================================================================
# RATE LIMITING
# =============================================================================
# Maximum connections per user
MAX_CONNECTIONS_PER_USER=5
# Connection timeout in milliseconds
CONNECTION_TIMEOUT_MS=60000
