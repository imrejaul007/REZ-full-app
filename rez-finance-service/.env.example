# Server
PORT=4005
NODE_ENV=development
SERVICE_NAME=rez-finance-service

# Database
# Generate credentials: openssl rand -base64 24
MONGO_INITDB_ROOT_USERNAME=rez_admin
MONGO_INITDB_ROOT_PASSWORD=change-me-generate-with-openssl-rand-base64-24
MONGODB_URI=mongodb://rez_admin:password@localhost:27017/rez-finance?authSource=admin

# Cache / Queue
# Generate password: openssl rand -hex 32
REDIS_PASSWORD=change-me-generate-with-openssl-rand-hex-32
# For authenticated Redis: redis://:password@localhost:6379
REDIS_URL=redis://:change-me-generate-with-openssl-rand-hex-32@localhost:6379

# Auth
JWT_SECRET=your_jwt_secret_here
INTERNAL_SERVICE_TOKEN=your_internal_token_here

# CORS
CORS_ORIGIN=https://rez.money,https://app.rez.money

# REZ Service URLs (for reward hooks and contextual triggers)
WALLET_SERVICE_URL=https://rez-wallet-service.onrender.com
GAMIFICATION_SERVICE_URL=https://rez-gamification-service-3b5d.onrender.com
ORDER_SERVICE_URL=https://rez-order-service.onrender.com
INTENT_CAPTURE_URL=https://rez-intent-graph.onrender.com

# Partner Aggregator (Phase 1 — FinBox)
FINBOX_API_KEY=
FINBOX_API_SECRET=
FINBOX_BASE_URL=https://api.finbox.in

# Credit Bureau (Phase 2)
EXPERIAN_CLIENT_ID=
EXPERIAN_CLIENT_SECRET=
EXPERIAN_BASE_URL=

# Sentry
SENTRY_DSN=

# Coins reward rates
COINS_PER_LOAN_DISBURSAL_PERCENT=0.5
COINS_CREDIT_CARD_APPROVAL=500
COINS_CREDIT_SCORE_CHECK=10
COINS_FIRST_EMI_BONUS=200

# === AML Compliance Limits [OPTIONAL] ===
# C-01 FIX: Anti-Money Laundering thresholds (in paise)
# CTR: Cash Transaction Report triggered when transactions exceed CASH_THRESHOLD
AML_CASH_THRESHOLD=10000000
# STR: Suspicious Transaction Report threshold
AML_STR_THRESHOLD=5000000
# Velocity limits per user
AML_DAILY_LIMIT=50000000
AML_WEEKLY_LIMIT=200000000
AML_MONTHLY_LIMIT=500000000
# BNPL-specific thresholds
AML_BNPL_LIMIT=100000
AML_BNPL_VELOCITY=50000
# Rapid exposure detection
AML_RAPID_EXPOSURE_WINDOW=2
AML_RAPID_EXPOSURE_COUNT=3
# Transaction frequency limits
AML_TX_COUNT_DAILY=20
AML_TX_COUNT_HOURLY=5
