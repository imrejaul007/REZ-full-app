# Karma Mobile App Environment Variables

# Karma Service API Base URL
EXPO_PUBLIC_KARMA_API_URL=https://rez-karma-service.onrender.com/v1/karma

# Optional: Analytics
EXPO_PUBLIC_ANALYTICS_ENABLED=false

# Sentry Error Tracking (Required for production)
# Get your DSN from https://sentry.io/settings/<org>/projects/<project>/keys/
SENTRY_DSN=
