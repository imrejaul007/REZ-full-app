# ── ReZ Travel Service - Environment Variables ────────────────────────────────────
# Copy this file to .env and fill in the values

# ── Environment ────────────────────────────────────────────────────────────────
NODE_ENV=development
SERVICE_NAME=rez-travel-service

# ── Server Ports ────────────────────────────────────────────────────────────────
PORT=4007
HEALTH_PORT=4107

# ── MongoDB ───────────────────────────────────────────────────────────────────
MONGODB_URI=mongodb://localhost:27017/rez_travel

# ── Redis ────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ── Authentication ──────────────────────────────────────────────────────────────
# Internal service token for server-to-server auth
INTERNAL_SERVICE_TOKEN=change-me-to-a-secure-random-string

# ── External APIs ──────────────────────────────────────────────────────────────
# TBO API credentials (for hotel/flight booking)
TBO_API_KEY=
TBO_API_SECRET=
TBO_CLIENT_ID=
TBO_API_URL=https://api.tbotech.in/v1

# ── Logging ───────────────────────────────────────────────────────────────────
LOG_LEVEL=info

# ── Observability ─────────────────────────────────────────────────────────────
SENTRY_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.1

# ── CORS ──────────────────────────────────────────────────────────────────────
CORS_ORIGIN=http://localhost:3000

# ── Service URLs (Inter-service communication) ─────────────────────────────────
AUTH_SERVICE_URL=http://localhost:4002
WALLET_SERVICE_URL=http://localhost:3010
ORDER_SERVICE_URL=http://localhost:4003
