# Service Configuration
PORT=4030
NODE_ENV=development

# Service Tokens (for inter-service authentication)
SERVICE_TOKEN=your-secure-service-token-here
POS_SERVICE_TOKEN=pos-service-secret-token
INVENTORY_SERVICE_TOKEN=inventory-service-secret-token

# Inventory Engine Connection
INVENTORY_ENGINE_URL=http://localhost:4021

# Retail POS Connection
RETAIL_POS_URL=http://localhost:4020

# MongoDB Connection (for sync state persistence)
MONGODB_URI=mongodb://localhost:27017/rez-pos-inventory-sync

# Sync Configuration
SYNC_BATCH_SIZE=100
SYNC_INTERVAL_MS=60000
MAX_RETRY_ATTEMPTS=3
